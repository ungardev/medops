---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
const plans = {
  'doctor': {
    name: 'DOCTOR',
    price: '$25',
    period: '/mes',
  },
  'doctor-plus': {
    name: 'ESPECIALISTA',
    price: '$40',
    period: '/mes',
  },
  'institution': {
    name: 'CLÍNICA',
    price: '$120',
    period: '/mes',
  },
};
const paymentMethods = [
  {
    icon: 'smartphone',
    name: 'Pago Móvil',
    description: 'Transferencia inmediata desde tu banco en Venezuela.',
    details: [
      'Teléfono: (se proporcionará al confirmar)',
      'Cédula: (se proporcionará al confirmar)',
      'Banco: (se proporcionará al confirmar)',
    ],
  },
  {
    icon: 'credit-card',
    name: 'Zelle',
    description: 'Ideal para pagos desde Estados Unidos.',
    details: [
      'Email: (se proporcionará al confirmar)',
      'Confirmación en 24-48 horas',
    ],
  },
  {
    icon: 'wallet',
    name: 'PayPal',
    description: 'Pago seguro internacional.',
    details: [
      'Email: (se proporcionará al confirmar)',
      'Comisión incluida en el precio',
    ],
  },
  {
    icon: 'building-2',
    name: 'Transferencia Bancaria',
    description: 'Transferencia nacional o internacional.',
    details: [
      'Datos bancarios al confirmar',
      'Disponible para bancos nacionales e internacionales',
    ],
  },
];
const iconPaths = {
  'smartphone': '<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>',
  'credit-card': '<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>',
  'wallet': '<path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3v-4z"/><path d="M3 5h14v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z"/>',
  'building-2': '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 12h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/>',
};
---
<Layout title="Checkout | MEDOPZ">
  <Navbar />
   
  <main class="relative min-h-screen pt-24 pb-16 px-6 overflow-hidden">
    <!-- Background Effects - Dual glow -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-emerald-500/5 rounded-full blur-[120px] animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[300px] bg-cyan-500/3 rounded-full blur-[100px] animate-pulse-slow" style="animation-delay: 1s;"></div>
    
    <div class="relative z-10 max-w-[800px] mx-auto">
      <!-- Breadcrumb -->
      <nav class="mb-8">
        <ol class="flex items-center gap-2 text-[11px] text-white/40">
          <li><a href="/" class="hover:text-white/60 transition-colors">MEDOPZ</a></li>
          <li>/</li>
          <li><a href="/#pricing" class="hover:text-white/60 transition-colors">Precios</a></li>
          <li>/</li>
          <li class="text-white/60">Checkout</li>
        </ol>
      </nav>
      
      <!-- Plan Selected -->
      <div class="relative group overflow-hidden rounded-xl p-6 mb-8 transition-all duration-500">
        <div class="absolute inset-0 bg-gradient-to-br from-white/[0.08] to-white/[0.02] backdrop-blur-xl rounded-xl border border-white/[0.08] transition-all duration-500 group-hover:border-white/[0.15]"></div>
        <div class="absolute inset-0 rounded-xl shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05)]"></div>
        <div class="absolute inset-0 rounded-xl opacity-0 transition-all duration-700 group-hover:opacity-100" style="background: radial-gradient(circle at 50% 0%, rgba(16, 185, 129, 0.15) 0%, transparent 60%);"></div>
        <div class="relative z-10 flex items-center justify-between">
          <div>
            <span class="text-[10px] font-medium text-white/40 uppercase tracking-wider">Plan seleccionado</span>
            <h1 id="plan-name" class="text-2xl font-bold text-white mt-1">DOCTOR</h1>
          </div>
<div class="text-right">
             <span id="plan-price" class="text-3xl font-bold text-emerald-400">$25</span>
             <span id="plan-period" class="text-[12px] text-white/40">/mes</span>
           </div>
         </div>
       </div>
      
      <!-- Payment Methods -->
      <div class="mb-8">
        <h2 class="text-[13px] font-semibold text-white mb-4 uppercase tracking-wider">Métodos de Pago Disponibles</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {paymentMethods.map((method) => (
            <div class="relative group overflow-hidden rounded-xl p-5 transition-all duration-500">
              <div class="absolute inset-0 bg-gradient-to-br from-white/[0.08] to-white/[0.02] backdrop-blur-xl rounded-xl border border-white/[0.08] transition-all duration-500 group-hover:border-white/[0.2] group-hover:from-white/[0.12]"></div>
              <div class="absolute inset-0 rounded-xl shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05)]"></div>
              <div class="absolute inset-0 rounded-xl opacity-0 transition-all duration-700 group-hover:opacity-100" style="background: radial-gradient(circle at 50% 0%, rgba(6, 182, 212, 0.15) 0%, transparent 60%);"></div>
              <div class="relative z-10">
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-10 h-10 rounded-lg bg-white/[0.05] border border-white/10 flex items-center justify-center transition-all duration-300 group-hover:bg-white/[0.1] group-hover:border-cyan-500/30 group-hover:shadow-[0_0_15px_rgba(6,182,212,0.2)]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/60 transition-all duration-300 group-hover:text-cyan-400" set:html={iconPaths[method.icon as keyof typeof iconPaths]}></svg>
                  </div>
                  <div>
                    <h3 class="text-[13px] font-medium text-white">{method.name}</h3>
                    <p class="text-[10px] text-white/40">{method.description}</p>
                  </div>
                </div>
                <ul class="space-y-1.5">
                  {method.details.map((detail) => (
                    <li class="flex items-start gap-2">
                      <span class="text-cyan-400/60 text-[10px] mt-0.5">•</span>
                      <span class="text-[11px] text-white/50">{detail}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <!-- How it Works -->
      <div class="relative group overflow-hidden rounded-xl p-6 mb-8 transition-all duration-500">
        <div class="absolute inset-0 bg-gradient-to-br from-white/[0.08] to-white/[0.02] backdrop-blur-xl rounded-xl border border-white/[0.08] transition-all duration-500 group-hover:border-white/[0.15]"></div>
        <div class="absolute inset-0 rounded-xl shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05)]"></div>
        <div class="absolute inset-0 rounded-xl opacity-0 transition-all duration-700 group-hover:opacity-100" style="background: radial-gradient(circle at 50% 0%, rgba(16, 185, 129, 0.12) 0%, transparent 60%);"></div>
        <div class="relative z-10">
        <h2 class="text-[13px] font-semibold text-white mb-4 uppercase tracking-wider">¿Cómo funciona?</h2>
        <div class="space-y-4">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-emerald-500/15 border border-emerald-500/25 flex items-center justify-center shrink-0">
              <span class="text-[11px] font-medium text-emerald-400">1</span>
            </div>
            <div>
              <h3 class="text-[12px] font-medium text-white mb-1">Envía tu solicitud</h3>
              <p class="text-[11px] text-white/50">Haz clic en el botón de abajo para enviarnos un email con tu plan seleccionado.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-emerald-500/15 border border-emerald-500/25 flex items-center justify-center shrink-0">
              <span class="text-[11px] font-medium text-emerald-400">2</span>
            </div>
            <div>
              <h3 class="text-[12px] font-medium text-white mb-1">Recibe los datos de pago</h3>
              <p class="text-[11px] text-white/50">Te responderemos en menos de 24 horas con los datos exactos para tu método de pago preferido.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-emerald-500/15 border border-emerald-500/25 flex items-center justify-center shrink-0">
              <span class="text-[11px] font-medium text-emerald-400">3</span>
            </div>
            <div>
              <h3 class="text-[12px] font-medium text-white mb-1">Activa tu cuenta</h3>
              <p class="text-[11px] text-white/50">Una vez confirmado el pago, activamos tu cuenta en menos de 24 horas.</p>
            </div>
          </div>
        </div>
        </div>
      </div>
      
      <!-- CTA -->
      <div class="text-center">
        <a 
          id="checkout-btn"
          href="mailto:info.medopz@gmail.com?subject=Solicitud de Compra - Plan DOCTOR&body=Hola equipo MEDOPZ,%0A%0AMe interesa comprar el plan DOCTOR ($25/mes).%0A%0ANombre completo:%0AEspecialidad:%0ACiudad:%0ATeléfono:%0AMétodo de pago preferido:%0A%0AGracias."
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-emerald-500/20 to-emerald-500/10 hover:from-emerald-500/30 hover:to-emerald-500/15 border border-emerald-500/30 text-emerald-400 text-[13px] font-medium rounded-xl transition-all hover:shadow-[0_0_25px_rgba(16,185,129,0.25)]"
        >
          Solicitar Compra - <span id="checkout-plan-name">DOCTOR</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="text-[11px] text-white/40 mt-4">
          Respuesta garantizada en menos de 24 horas.
        </p>
      </div>
    </div>
  </main>
  
  <Footer />
  
  <!-- Client-side script para leer query params -->
  <script>
    const planData = {
      'doctor': { name: 'DOCTOR', price: '$25', period: '/mes' },
      'doctor-plus': { name: 'ESPECIALISTA', price: '$40', period: '/mes' },
      'institution': { name: 'CLÍNICA', price: '$120', period: '/mes' },
    };
    const params = new URLSearchParams(window.location.search);
    const selectedPlan = params.get('plan') || 'doctor';
    const plan = planData[selectedPlan] || planData['doctor'];
    const planNameEl = document.getElementById('plan-name');
    const planPriceEl = document.getElementById('plan-price');
    const planPeriodEl = document.getElementById('plan-period');
    const checkoutBtn = document.getElementById('checkout-btn');
    const checkoutPlanName = document.getElementById('checkout-plan-name');
    if (planNameEl) planNameEl.textContent = plan.name;
    if (planPriceEl) planPriceEl.textContent = plan.price;
    if (planPeriodEl) planPeriodEl.textContent = plan.period;
    if (checkoutPlanName) checkoutPlanName.textContent = plan.name;
    
    if (checkoutBtn) {
      const subject = encodeURIComponent(`Solicitud de Compra - Plan ${plan.name}`);
      const body = encodeURIComponent(
        `Hola equipo MEDOPZ,\n\nMe interesa comprar el plan ${plan.name} (${plan.price}${plan.period}).\n\nNombre completo:\nEspecialidad:\nCiudad:\nTeléfono:\nMétodo de pago preferido:\n\nGracias.`
      );
      checkoutBtn.setAttribute('href', `mailto:info.medopz@gmail.com?subject=${subject}&body=${body}`);
    }
  </script>

<style>
  @keyframes pulse-slow {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05); }
  }
  
  .animate-pulse-slow {
    animation: pulse-slow 4s ease-in-out infinite;
  }
</style>
</Layout>