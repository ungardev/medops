---
const doctorModules = [
  {
    icon: 'dashboard',
    title: 'Dashboard Clínico',
    description: 'Overview institucional, telemetría de rendimiento y analítica predictiva de la sede.'
  },
  {
    icon: 'waitingroom',
    title: 'Sala de Espera Live',
    description: 'Control y automatización del tráfico de pacientes en tiempo real con sincronización invisible de fondo.'
  },
  {
    icon: 'consultation',
    title: 'Estación de Consulta',
    description: 'Evolución clínica dinámica, captura de signos vitales y estructuración de recetas digitales inmutables homologadas ante el INHRR.'
  },
  {
    icon: 'diagnosis',
    title: 'Motor de Diagnóstico',
    description: 'Indexación y búsqueda de alta velocidad bajo estándares internacionales CIE-11 (WHO) y SNOMED CT.'
  },
  {
    icon: 'surgery',
    title: 'Módulo Quirúrgico',
    description: 'Planificación avanzada de quirófanos, asignación de pisos y censo de hospitalización en tiempo real.'
  },
  {
    icon: 'hospitalization',
    title: 'Gestión de Camas',
    description: 'Control de ocupación, asignación de pisos y monitoreo de estado de hospitalización.'
  },
  {
    icon: 'patients',
    title: 'Expediente Clínico',
    description: 'Registro digital unificado del paciente con historial completo, alertas y seguimiento longitudinal.'
  },
  {
    icon: 'appointments',
    title: 'Agenda Médica',
    description: 'Programación inteligente de citas, calendario interactivo y gestión de disponibilidad horaria.'
  },
  {
    icon: 'payments',
    title: 'Pasarela Financiera',
    description: 'Emisión automatizada de órdenes de cobro con conciliación bancaria instantánea (API Bancaribe, Binance Pay y Tasación BCV).'
  },
  {
    icon: 'services',
    title: 'Catálogo de Servicios',
    description: 'Gestión integral de procedimientos, tarifas, especialidades y asignaciones del staff médico.'
  },
  {
    icon: 'reports',
    title: 'Reporting Ejecutivo',
    description: 'Dashboard financiero y clínico con métricas KPI, generación de informes y analítica predictiva.'
  },
  {
    icon: 'settings',
    title: 'Configuración Institucional',
    description: 'Perfil del médico, datos de la institución, firma digital criptográfica y gestión de credenciales MPPS.'
  },
];

const patientModules = [
  {
    icon: 'marketplace',
    title: 'Marketplace de Salud',
    description: 'Buscador indexado de especialidades, procedimientos disponibles, tarifas transparentes y asignación automática del Doctor especialista.'
  },
  {
    icon: 'record',
    title: 'Expediente Clínico Personal (PHR)',
    description: 'Historial médico universal encriptado, descarga de prescripciones firmadas digitalmente y trazabilidad epidemiológica.'
  },
  {
    icon: 'appointments',
    title: 'Agenda Autónoma',
    description: 'Reservación, reprogramación y confirmación de citas en tiempo real según la disponibilidad del médico.'
  },
  {
    icon: 'payments',
    title: 'Centro de Liquidación',
    description: 'Historial de pagos inmutable, visualización de cuentas por pagar y procesamiento de facturas mediante pasarelas QR nativas.'
  },
  {
    icon: 'settings',
    title: 'Configuración de Perfil',
    description: 'Gestión de datos personales, preferencias de comunicación y configuración de seguridad de cuenta.'
  },
];
---

<section id="modules" class="py-24 lg:py-32 px-6 bg-[#050608] relative">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1a1e23_1px,transparent_1px),linear-gradient(to_bottom,#1a1e23_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-[0.04]"></div>

  <div class="max-w-[1400px] mx-auto relative">
    <div class="text-center mb-20">
      <span class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em]">Módulos Core</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-4 tracking-tight">
        Arquitectura Modular de Grado Institucional
      </h2>
      <p class="text-lg text-slate-300 mt-4 max-w-[800px] mx-auto leading-relaxed">
        Una suite robusta de ingeniería médica y financiera distribuida en dos entornos nativos que interoperan en tiempo real bajo un mismo núcleo de base de datos.
      </p>
    </div>

    <!-- Doctor Portal Suite -->
    <div class="mb-20">
      <div class="flex items-center gap-4 mb-10">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-slate-700 to-transparent"></div>
        <span class="text-xs font-bold text-white/50 uppercase tracking-[0.2em] px-4">Suite de Control Clínico — Doctor Portal</span>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-slate-700 to-transparent"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {doctorModules.map((module) => (
          <div class="group relative p-6 bg-slate-900/20 border border-slate-800/60 rounded-xl transition-all duration-500 hover:border-emerald-500/30 hover:bg-slate-900/30">
            <div class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-lg bg-slate-800/60 border border-slate-700/50 flex items-center justify-center shrink-0 transition-all duration-300 group-hover:border-emerald-500/30">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-emerald-400 transition-colors">
                  {module.icon === 'dashboard' && <><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></>}
                  {module.icon === 'waitingroom' && <><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></>}
                  {module.icon === 'consultation' && <><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><circle cx="20" cy="10" r="2"/></>}
                  {module.icon === 'diagnosis' && <><path d="M2 8V6a2 2 0 0 1 2-2h2"/><path d="M2 16v2a2 2 0 0 0 2 2h8"/><path d="M6 12H4a2 2 0 0 1-2-2V8"/><path d="M22 12h-2a2 2 0 0 1 2-2h2a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-2a2 2 0 0 1-2 2"/></>}
                  {module.icon === 'surgery' && <><path d="M6 2v6"/><path d="M6 16v6"/><path d="M2 6h6"/><path d="M2 18h6"/><path d="M16 6h6"/><path d="M16 18h6"/><path d="M12 6v12"/></>}
                  {module.icon === 'hospitalization' && <><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></>}
                  {module.icon === 'patients' && <><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
                  {module.icon === 'appointments' && <><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></>}
                  {module.icon === 'payments' && <><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></>}
                  {module.icon === 'services' && <><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></>}
                  {module.icon === 'reports' && <><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></>}
                  {module.icon === 'settings' && <><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></>}
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-white mb-2 leading-tight">{module.title}</h3>
                <p class="text-sm text-slate-400 leading-relaxed">{module.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Patient Portal Suite -->
    <div>
      <div class="flex items-center gap-4 mb-10">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-slate-700 to-transparent"></div>
        <span class="text-xs font-bold text-white/50 uppercase tracking-[0.2em] px-4">Suite Transaccional del Paciente — Patient Portal</span>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-slate-700 to-transparent"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {patientModules.map((module) => (
          <div class="group relative p-6 bg-slate-900/20 border border-slate-800/60 rounded-xl transition-all duration-500 hover:border-emerald-500/30 hover:bg-slate-900/30">
            <div class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-lg bg-slate-800/60 border border-slate-700/50 flex items-center justify-center shrink-0 transition-all duration-300 group-hover:border-emerald-500/30">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-emerald-400 transition-colors">
                  {module.icon === 'marketplace' && <><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/><circle cx="18" cy="18" r="3"/><circle cx="18" cy="15" r="1"/></>}
                  {module.icon === 'record' && <><path d="M4 22h14a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M9 15h6"/></>}
                  {module.icon === 'appointments' && <><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></>}
                  {module.icon === 'payments' && <><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/><path d="M6 18h2"/><path d="M12 18h4"/></>}
                  {module.icon === 'settings' && <><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></>}
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-white mb-2 leading-tight">{module.title}</h3>
                <p class="text-sm text-slate-400 leading-relaxed">{module.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>