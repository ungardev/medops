---
const modules = [
  {
    icon: 'dashboard',
    title: 'Dashboard',
    description: 'Métricas en tiempo real y overview institucional',
    placeholder: 'Dashboard',
  },
  {
    icon: 'waitingroom',
    title: 'Sala de Espera',
    description: 'Cola de pacientes en tiempo real con polling 30s',
    placeholder: 'Sala de Espera',
  },
  {
    icon: 'consultation',
    title: 'Consulta',
    description: 'Notas clínicas, signos vitales y diagnósticos',
    placeholder: 'Consulta',
  },
  {
    icon: 'diagnosis',
    title: 'Diagnóstico',
    description: 'CIE-11 + SNOMED CT búsqueda inteligente',
    placeholder: 'Diagnóstico',
  },
  {
    icon: 'surgery',
    title: 'Cirugía',
    description: 'Gestión de quirófanos y procedimientos',
    placeholder: 'Cirugía',
  },
  {
    icon: 'hospitalization',
    title: 'Hospitalización',
    description: 'Asignación de camas y gestión de pisos',
    placeholder: 'Hospitalización',
  },
  {
    icon: 'patients',
    title: 'Pacientes',
    description: 'Expediente digital y historial clínico completo',
    placeholder: 'Pacientes',
  },
  {
    icon: 'appointments',
    title: 'Citas',
    description: 'Agenda interactiva y calendario médico',
    placeholder: 'Citas',
  },
  {
    icon: 'payments',
    title: 'Pagos',
    description: 'QR Bancaribe, Binance Crypto, BCV Rate',
    placeholder: 'Pagos',
  },
  {
    icon: 'services',
    title: 'Servicios',
    description: 'Catálogo de servicios médicos',
    placeholder: 'Servicios',
  },
  {
    icon: 'reports',
    title: 'Reportes',
    description: 'Dashboard financiero y clínico',
    placeholder: 'Reportes',
  },
  {
    icon: 'settings',
    title: 'Configuración',
    description: 'Perfil doctor, institución y firma digital',
    placeholder: 'Configuración',
  },
];
---

<section id="modules" class="py-24 lg:py-32 px-6 bg-[#050608] relative overflow-hidden">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1a1e23_1px,transparent_1px),linear-gradient(to_bottom,#1a1e23_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-[0.04]"></div>

  <div class="max-w-[1200px] mx-auto relative">
    <div class="text-center mb-16">
      <span class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em]">Módulos</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-4 tracking-tight">
        Operaciones Médicas Integrales
      </h2>
      <p class="text-lg text-slate-300 mt-4 max-w-[700px] mx-auto leading-relaxed">
        12 módulos interconectados para gestionar el ciclo completo del paciente
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {modules.map((module, index) => (
        <div class="group relative p-6 bg-[#0c0e12] border border-[#1a1e23] rounded-2xl transition-all duration-500 hover:border-emerald-500/30">
          <div class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0a0a0b] border border-[#1a1e23] flex items-center justify-center shrink-0 transition-all duration-300 group-hover:border-emerald-500/30">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-emerald-400 transition-colors">
                {module.icon === 'dashboard' && <><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></>}
                {module.icon === 'waitingroom' && <><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></>}
                {module.icon === 'consultation' && <><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><circle cx="20" cy="10" r="2"/></>}
                {module.icon === 'diagnosis' && <><path d="M2 8V6a2 2 0 0 1 2-2h2"/><path d="M2 16v2a2 2 0 0 0 2 2h8"/><path d="M6 12H4a2 2 0 0 1-2-2V8"/><path d="M22 12h-2a2 2 0 0 1 2-2h2a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-2a2 2 0 0 1-2 2"/></>}
                {module.icon === 'surgery' && <><path d="M6 2v6"/><path d="M6 16v6"/><path d="M2 6h6"/><path d="M2 18h6"/><path d="M16 6h6"/><path d="M16 18h6"/><path d="M12 6v12"/></>}
                {module.icon === 'hospitalization' && <><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></>}
                {module.icon === 'patients' && <><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
                {module.icon === 'appointments' && <><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></>}
                {module.icon === 'payments' && <><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></>}
                {module.icon === 'services' && <><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></>}
                {module.icon === 'reports' && <><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></>}
                {module.icon === 'settings' && <><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></>}
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-semibold text-white mb-1">{module.title}</h3>
              <p class="text-sm text-slate-400 leading-relaxed">{module.description}</p>
            </div>
          </div>

          <div class="bg-[#050608] border border-slate-800/60 rounded-xl h-[100px] flex items-center justify-center">
            <span class="text-slate-600 text-xs font-mono">[Screenshot: {module.placeholder}]</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>