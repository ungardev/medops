---
const plans = [
  {
    name: 'Professional',
    price: '$25',
    period: '/ médico / mes',
    description: 'Infraestructura óptima para consultas independientes y médicos especialistas autónomos.',
    features: [
      'Récord clínico digital completo',
      'Buscador inteligente e indexado CIE-11',
      'Módulo de recetas digitales INHRR',
      'Órdenes de cobro y control operativo de 1 sede',
      'Sala de espera live',
      'Portal paciente básico',
    ],
    cta: 'Comenzar',
    href: 'https://app.medopz.com/',
    featured: false,
  },
  {
    name: 'Institutional',
    price: '$40',
    period: '/ médico / mes',
    description: 'Diseñado para clínicas, centros de diagnóstico y policlínicas con múltiples dependencias.',
    features: [
      'Todo lo incluido en Professional',
      'Arquitectura e interconexión Multi-Sede',
      'Gestión de quirófanos y asignación de camas',
      'Matriz de seguridad con permisos granulares por roles',
      'Acceso a la API de Telemetría Financiera',
      'Soporte priorario 24/7',
    ],
    cta: 'Contactar Soluciones',
    href: 'mailto:info@medopz.com?subject=Plan Institutional',
    featured: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'The MEDOPZ Transactional Engine. Infraestructura masiva y exclusiva para redes hospitalarias y banca corporativa.',
    features: [
      'Instancia aislada y base de datos dedicada de alta disponibilidad',
      'Pasarela de recaudación integrada (Mercantil P2C / Banesco)',
      'Conciliación automatizada masiva en tiempo real',
      'SLA prioritario 24/7/365',
    ],
    cta: 'Consultar Comité',
    href: 'mailto:info@medopz.com?subject=The MEDOPZ Transactional Engine',
    featured: false,
  },
];
---

<section id="pricing" class="py-24 lg:py-32 px-6 bg-[#050608] border-t border-[#1a1e23] relative">
  <div class="max-w-[1200px] mx-auto">
    <!-- Section Header -->
    <div class="text-center max-w-[800px] mx-auto mb-16">
      <span class="text-xs font-bold text-[#10b981] uppercase tracking-[0.2em]">Precios</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-4 tracking-tight">
        Modelos de Licenciamiento
      </h2>
      <p class="text-lg text-slate-300 mt-4">Inversión inteligente adaptada a la escala de su institución</p>
      <p class="text-sm text-slate-500 mt-2">Estructura SaaS por suscripción mensual calculada por médico activo.</p>
    </div>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
      {plans.map((plan) => (
        <div 
          class={`relative flex flex-col justify-between p-8 rounded-2xl transition-all duration-300 ${
            plan.featured 
              ? 'bg-[#0c0e12] border-2 border-[#10b981] shadow-[0_0_40px_rgba(16,185,129,0.08)] transform md:-translate-y-2' 
              : 'bg-[#0c0e12] border border-[#1a1e23] hover:border-slate-700'
          }`}
        >
          {plan.featured && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[#10b981] text-black text-[10px] font-bold tracking-widest uppercase px-4 py-1.5 rounded-full">
              Más Seleccionado
            </div>
          )}
          
          <div>
            <!-- Plan Name -->
            <span class="text-xs font-bold tracking-widest text-slate-400 uppercase">{plan.name}</span>
            
            <!-- Price -->
            <div class="flex items-baseline gap-1 mt-4">
              <span class="text-5xl font-bold text-white">{plan.price}</span>
              {plan.period && <span class="text-slate-500 text-sm">{plan.period}</span>}
            </div>
            
            <!-- Description -->
            <p class="text-sm text-slate-400 mt-4 leading-relaxed">{plan.description}</p>
            
            <div class="h-px bg-[#1a1e23] my-6"></div>
            
            <!-- Features -->
            <ul class="space-y-4">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm text-white">
                  <span class="text-[#10b981] font-bold mt-0.5">✓</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <!-- CTA -->
          <a 
            href={plan.href}
            class={`mt-8 block w-full text-center py-3 px-4 rounded-xl font-medium transition-all duration-300 text-sm ${
              plan.featured
                ? 'bg-[#10b981] text-black font-bold hover:bg-[#0d9488]'
                : 'border border-[#1a1e23] text-white hover:bg-[#1a1e23]'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #pricing .grid > div {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  
  #pricing .grid > div.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const section = document.getElementById('pricing');
  const cards = section?.querySelectorAll('.grid > div');
  
  if (cards?.length && section) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          cards.forEach((card, i) => {
            setTimeout(() => {
              card.classList.add('visible');
            }, i * 100);
          });
          observer.disconnect();
        }
      });
    }, { threshold: 0.15 });
    
    observer.observe(section);
  }
</script>