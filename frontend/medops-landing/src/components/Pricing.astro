---
const plans = [
  {
    name: 'DOCTOR',
    price: '$25',
    period: '/mes',
    description: 'Para el médico independiente.',
    features: [
      'Consulta CIE-11',
      'Recetas digitales',
      'Historial clínico',
      'Sala de espera',
      'Dashboard',
    ],
    cta: 'Comenzar',
    ctaUrl: '/checkout/?plan=doctor',
    ctaStyle: 'secondary',
  },
  {
    name: 'ESPECIALISTA',
    price: '$40',
    period: '/mes',
    description: 'Portal Paciente incluido.',
    features: [
      'Todo Doctor',
      'Portal Paciente',
      'Cirugías',
      'Hospitalización',
      'Soporte prioritario',
    ],
    cta: 'Comenzar',
    ctaUrl: '/checkout/?plan=doctor-plus',
    ctaStyle: 'primary',
    popular: true,
  },
  {
    name: 'CLÍNICA',
    price: '$120',
    period: '/mes',
    description: 'Múltiples sedes.',
    features: [
      'Todo Especialista',
      'Multi-sede',
      'Gestión de camas',
      'Dashboard',
      'Facturación',
      'Soporte 24/7',
    ],
    cta: 'Contactar',
    ctaUrl: '/checkout/?plan=institution',
    ctaStyle: 'secondary',
  },
];
---

<section id="pricing" class="py-32 px-6 relative">
  <!-- Background Effects -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/3 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-emerald-500/5 rounded-full blur-[100px]"></div>
    <div class="absolute top-1/3 right-1/4 translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-cyan-500/5 rounded-full blur-[80px]"></div>
  </div>
  
  <div class="max-w-[1200px] mx-auto relative">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <span class="text-[12px] font-medium text-emerald-400/80 uppercase tracking-[0.2em]">Planes</span>
      <h2 class="text-4xl sm:text-5xl font-bold text-white mt-4 tracking-tight">
        Precios a la Medida
        <span class="block text-white/50 font-normal mt-2">de tu alcance</span>
      </h2>
    </div>
    
    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {plans.map((plan, index) => (
        <div 
          class={`group relative rounded-2xl p-6 pt-10 transition-all duration-500 ${
            plan.popular ? 'col-span-1' : ''
          }`}
          style={`animation-delay: ${index * 100}ms`}
        >
          <!-- Glassmorphism Background -->
          <div class={`absolute inset-0 bg-gradient-to-b from-white/[0.08] to-white/[0.02] backdrop-blur-xl rounded-2xl border transition-all duration-500 ${
            plan.popular 
              ? 'border-emerald-500/30 group-hover:border-emerald-500/50' 
              : 'border-white/[0.08] group-hover:border-white/[0.2]'
          }`}></div>
          
          <!-- Inner Shadow -->
          <div class="absolute inset-0 rounded-2xl shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05)] transition-all duration-500 group-hover:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.1)]"></div>
          
          <!-- Glow Effects -->
          <div class="absolute inset-0 rounded-2xl opacity-0 transition-all duration-700 group-hover:opacity-100" style={`background: radial-gradient(circle at 50% 0%, ${plan.popular ? 'rgba(16, 185, 129, 0.2)' : 'rgba(6, 182, 212, 0.15)'} 0%, transparent 60%);`}></div>
          <div class={`absolute -bottom-20 -right-20 w-40 h-40 rounded-full blur-[40px] opacity-0 transition-all duration-700 group-hover:opacity-100 ${
            plan.popular ? 'bg-emerald-500/15' : 'bg-cyan-500/10'
          }`}></div>
          
          <!-- Popular Badge -->
          {plan.popular && (
            <div class="absolute -top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 px-4 py-1.5 bg-gradient-to-r from-emerald-500/20 to-emerald-500/10 border border-emerald-500/40 rounded-full shadow-[0_0_20px_rgba(16,185,129,0.3)] z-50">
              <span class="text-[10px] font-semibold text-emerald-400 uppercase tracking-wider">Más Popular</span>
            </div>
          )}
          
          <!-- Content -->
          <div class="relative z-10">
            <!-- Header -->
            <div class="mb-6">
              <span class="text-[12px] font-medium text-white/60 uppercase tracking-wider">{plan.name}</span>
              <div class="flex items-baseline gap-1 mt-2">
                <span class={`text-4xl font-bold tracking-tight ${
                  plan.popular ? 'text-emerald-400' : 'text-white'
                }`}>{plan.price}</span>
                <span class="text-[13px] text-white/50">{plan.period}</span>
              </div>
              <p class="text-[13px] text-white/50 mt-2 leading-relaxed">{plan.description}</p>
            </div>
            
            <!-- Features -->
            <ul class="space-y-3 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-md bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center shrink-0">
                    <svg class="w-3 h-3 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <span class="text-[13px] text-white/70">{feature}</span>
                </li>
              ))}
            </ul>
            
            <!-- CTA Button -->
            <a 
              href={plan.ctaUrl}
              class={`w-full inline-flex items-center justify-center gap-2 px-4 py-3 text-[12px] font-medium rounded-xl transition-all ${
                plan.ctaStyle === 'primary'
                  ? 'bg-emerald-500/15 hover:bg-emerald-500/25 border border-emerald-500/30 text-emerald-400 hover:shadow-[0_0_20px_rgba(16,185,129,0.2)]'
                  : 'bg-white/[0.08] hover:bg-white/[0.12] border border-white/[0.1] text-white/80 hover:border-white/[0.2]'
              }`}
            >
              {plan.cta}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #pricing > div > .grid > div {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  
  #pricing > div > .grid > div.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const section = document.getElementById('pricing');
  const cards = section?.querySelectorAll('#pricing > div > .grid > div');
  
  if (cards?.length && section) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          cards.forEach((card, i) => {
            setTimeout(() => {
              card.classList.add('visible');
            }, i * 100);
          });
          observer.disconnect();
        }
      });
    }, { threshold: 0.2 });
    
    observer.observe(section);
  }
</script>