---
const plans = [
  {
    name: 'DOCTOR',
    price: '$29',
    period: '/mes',
    description: 'Para el médico independiente que quiere digitalizar su consulta.',
    features: [
      'Consulta con diagnóstico CIE-11',
      'Recetas y tratamientos digitales',
      'Historial clínico completo',
      'Sala de espera inteligente',
      'Dashboard financiero personal',
      'Soporte por email',
    ],
    cta: 'Comprar',
    ctaUrl: '/checkout?plan=doctor',
    ctaStyle: 'secondary',
  },
  {
    name: 'DOCTOR +',
    price: '$59',
    period: '/mes',
    description: 'Para el especialista que quiere ofrecer una experiencia premium.',
    features: [
      'Todo lo del plan Doctor',
      'Portal del Paciente incluido',
      'Gestión de cirugías completa',
      'Hospitalización y camas',
      'SNOMED CT (cuando esté disponible)',
      'Soporte prioritario',
    ],
    cta: 'Comprar',
    ctaUrl: '/checkout?plan=doctor-plus',
    ctaStyle: 'primary',
    popular: true,
  },
  {
    name: 'INSTITUTION',
    price: '$149',
    period: '/mes',
    description: 'Para clínicas y hospitales que buscan gestión integral.',
    features: [
      'Todo lo del plan Doctor +',
      'Multi-sede ilimitado',
      'Gestión de camas y pabellones',
      'Dashboard institucional',
      'RRHH médico',
      'Facturación y reportes',
      'Soporte dedicado 24/7',
    ],
    cta: 'Contactar Ventas',
    ctaUrl: '/checkout?plan=institution',
    ctaStyle: 'secondary',
  },
];
---
<section id="pricing" class="py-24 px-6">
  <div class="max-w-[1200px] mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="text-[12px] font-medium text-emerald-400/80 uppercase tracking-wider">Precios</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mt-3 tracking-tight">
        Planes que escalan
        <span class="block text-white/60 font-normal mt-1">con tu práctica médica.</span>
      </h2>
    </div>
    
    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {plans.map((plan) => (
        <div class={`relative bg-white/5 border rounded-lg p-6 transition-all ${
          plan.popular ? 'border-emerald-500/25' : 'border-white/10 hover:border-white/20'
        }`}>
          {plan.popular && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-emerald-500/15 border border-emerald-500/25 rounded-full">
              <span class="text-[10px] font-medium text-emerald-400 uppercase tracking-wider">Más Popular</span>
            </div>
          )}
          
          <div class="mb-6">
            <span class="text-[11px] font-medium text-white/60 uppercase tracking-wider">{plan.name}</span>
            <div class="flex items-baseline gap-1 mt-2">
              <span class="text-3xl font-bold text-white tracking-tight">{plan.price}</span>
              <span class="text-[12px] text-white/60">{plan.period}</span>
            </div>
            <p class="text-[12px] text-white/60 mt-2 leading-relaxed">{plan.description}</p>
          </div>
          
          <ul class="space-y-3 mb-8">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-emerald-400/80 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-[12px] text-white/60">{feature}</span>
              </li>
            ))}
          </ul>
          
          <a 
            href={plan.ctaUrl}
            class={`w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 text-[11px] font-medium rounded-lg transition-all ${
              plan.ctaStyle === 'primary'
                ? 'bg-emerald-500/15 hover:bg-emerald-500/25 border border-emerald-500/25 text-emerald-400'
                : 'bg-white/5 hover:bg-white/10 border border-white/15 text-white/70'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>