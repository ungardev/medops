---
const plans = [
  {
    name: 'Professional',
    price: '$25',
    period: '/ médico / mes',
    description: 'Infraestructura de alta disponibilidad óptima para consultas independientes y médicos especialistas autónomos que requieren blindaje operativo.',
    features: [
      'Expediente Clínico Digital Unificado e Inmutable',
      'Motor de Búsqueda Indexado CIE-11 y SNOMED CT',
      'Módulo de Prescripción Digital Homologado INHRR',
      'Órdenes de Cobro y Liquidación Multi-Moneda (1 Sede)',
      'Sala de Espera Live con Sincronización Automatizada',
      'Ecosistema Omnicanal con Acceso Nativo al Portal Paciente',
    ],
    cta: 'Desplegar Workstation',
    href: 'https://app.medopz.com/',
    featured: false,
  },
  {
    name: 'Institutional',
    price: '$40',
    period: '/ médico / mes',
    description: 'Diseñado para clínicas, policlínicas y centros de diagnóstico con flujos complejos y múltiples dependencias operativas interconectadas.',
    features: [
      'Todo lo incluido en el nivel Professional',
      'Arquitectura de Datos Multi-Sede Federada',
      'Control Logístico de Quirófanos y Asignación de Camas',
      'Matriz de Seguridad con Permisos Granulares por Roles',
      'Consola Centralizada de Telemetría y Conciliación Financiera',
      'Soporte Prioritario de Infraestructura 24/7/365',
    ],
    cta: 'Contactar Ingeniería de Soluciones',
    href: 'mailto:info@medopz.com?subject=Plan Institutional',
    featured: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'The MEDOPZ Transactional Engine. Infraestructura masiva, aislada y exclusiva para redes hospitalarias de alta escala y banca corporativa.',
    features: [
      'Instancia Aislada y Base de Datos Dedicada en NeonDB/PostgreSQL',
      'Rieles de Recaudación Core API (Bancaribe Core / Mercantil P2C / Banesco)',
      'Procesamiento Asincrónico y Conciliación Automatizada Masiva',
      'Gobernanza de Datos de Extremo a Extremo (Cumplimiento HIPAA / HL7)',
      'Entorno de Pruebas (Sandbox) para Pruebas de Carga y Estrés',
      'SLA Prioritario y Comité Técnico de Ingeniería Dedicado',
    ],
    cta: 'Solicitar Auditoría de Comité',
    href: 'mailto:info@medopz.com?subject=The MEDOPZ Transactional Engine',
    featured: false,
  },
];
---

<section id="plans" class="py-24 lg:py-32 px-6 bg-[#050608] border-t border-[#1a1e23] relative">
  <div class="max-w-[1200px] mx-auto">
    <!-- Section Header -->
    <div class="text-center max-w-[800px] mx-auto mb-16">
      <span class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em]">Precios</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-4 tracking-tight">
        Modelos de Licenciamiento
      </h2>
      <p class="text-lg text-slate-300 mt-4">Inversión inteligente adaptada a la escala de su institución</p>
      <p class="text-sm text-slate-500 mt-2">Estructura de licenciamiento por suscripción calculada por nodo de especialista clínico activo.</p>
    </div>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
      {plans.map((plan) => (
        <div 
          class={`relative flex flex-col justify-between p-8 rounded-2xl transition-all duration-300 ${
            plan.featured 
              ? 'bg-[#0c0e12] border-2 border-emerald-500 shadow-[0_0_40px_rgba(16,185,129,0.08)] transform md:-translate-y-2' 
              : 'bg-[#0c0e12] border border-[#1a1e23] hover:border-slate-700'
          }`}
        >
          {plan.featured && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-emerald-500 text-black text-[10px] font-bold tracking-widest uppercase px-4 py-1.5 rounded-full">
              Más Seleccionado
            </div>
          )}
          
          <div>
            <!-- Plan Name -->
            <span class="text-xs font-bold tracking-widest text-slate-400 uppercase">{plan.name}</span>
            
            <!-- Price -->
            <div class="flex items-baseline gap-1 mt-4">
              <span class={`text-5xl font-bold ${plan.featured ? 'text-emerald-400' : 'text-white'}`}>{plan.price}</span>
              {plan.period && <span class="text-slate-500 text-sm">{plan.period}</span>}
            </div>
            
            <!-- Description -->
            <p class="text-sm text-slate-400 mt-4 leading-relaxed">{plan.description}</p>
            
            <div class="h-px bg-[#1a1e23] my-6"></div>
            
            <!-- Features -->
            <ul class="space-y-4">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm text-white">
                  <span class="text-emerald-400 font-bold mt-0.5">✓</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <!-- CTA -->
          <a 
            href={plan.href}
            class={`mt-8 block w-full text-center py-3 px-4 rounded-xl font-medium transition-all duration-300 text-sm ${
              plan.featured
                ? 'bg-emerald-500/15 hover:bg-emerald-500/25 border border-emerald-500/25 text-emerald-400 hover:text-emerald-300'
                : 'border border-[#1a1e23] text-white hover:bg-white/5'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #plans .grid > div {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  
  #plans .grid > div.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const section = document.getElementById('plans');
  const cards = section?.querySelectorAll('.grid > div');
  
  if (cards?.length && section) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          cards.forEach((card, i) => {
            setTimeout(() => {
              card.classList.add('visible');
            }, i * 100);
          });
          observer.disconnect();
        }
      });
    }, { threshold: 0.15 });
    
    observer.observe(section);
  }
</script>