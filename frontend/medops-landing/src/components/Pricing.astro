---
const plans = [
  {
    name: 'Professional',
    price: '$25',
    period: '/ médico / mes',
    description: 'Ideal para médicos independientes',
    features: [
      'Expediente Clínico Digital',
      'Codificación CIE-11 / SNOMED',
      'Prescripción Digital INHRR',
      'Wallet con Bancaribe',
    ],
    cta: 'Desplegar Workstation',
    href: 'https://app.medopz.com/',
    featured: false,
  },
  {
    name: 'Institutional',
    price: '$40',
    period: '/ médico / mes',
    description: 'Para clínicas y consultorios múltiples',
    features: [
      'Todo lo de Professional',
      'Multi-Sede Federada',
      'Quirófanos y Camas',
      'Soporte 24/7',
    ],
    cta: 'Hablar con Ventas',
    href: 'mailto:info@medopz.com?subject=Consultas sobre Planes',
    featured: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'Para hospitales y redes grandes',
    features: [
      'Instancia Aislada Dedicada',
      'Core API + Conciliación',
      'Cumplimiento HIPAA / HL7',
      'SLA y Comité Técnico',
    ],
    cta: 'Solicitar Auditoría',
    href: 'mailto:info@medopz.com?subject=The MEDOPZ Transactional Engine',
    featured: false,
  },
];
---

<section id="plans" class="py-24 lg:py-32 px-6 bg-transparent border-t border-[#1a1e23] relative">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center max-w-[800px] mx-auto mb-16">
      <span class="text-base font-bold text-emerald-400 uppercase tracking-[0.2em]">Precios</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-4 tracking-tight">
        Planes Simples y Transparentes
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
      {plans.map((plan) => (
        <div 
          class={`relative flex flex-col justify-between p-8 rounded-2xl transition-all duration-300 ${
            plan.featured 
              ? 'bg-[#0c0e12] border-2 border-emerald-500 shadow-[0_0_40px_rgba(16,185,129,0.08)] transform md:-translate-y-2' 
              : 'bg-[#0c0e12] border border-[#1a1e23] hover:border-slate-700'
          }`}
        >
          {plan.featured && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-emerald-500 text-black text-[10px] font-bold tracking-widest uppercase px-4 py-1.5 rounded-full">
              Más Seleccionado
            </div>
          )}
          
          <div>
            <span class="text-xs font-bold tracking-widest text-slate-400 uppercase">{plan.name}</span>
            
            <div class="flex items-baseline gap-1 mt-4">
              <span class={`text-5xl font-bold ${plan.featured ? 'text-emerald-400' : 'text-white'}`}>{plan.price}</span>
              {plan.period && <span class="text-slate-400 text-sm">{plan.period}</span>}
            </div>
            
            <p class="text-sm text-slate-300 mt-4 font-medium">{plan.description}</p>
            
            <div class="h-px bg-[#1a1e23] my-6"></div>
            
            <ul class="space-y-4 text-center md:text-left">
              {plan.features.map((feature) => (
                <li class="flex items-center md:items-start justify-center md:justify-start gap-3 text-sm text-white">
                  <span class="text-emerald-400 font-bold mt-0.5">✓</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <a 
            href={plan.href}
            class={`mt-8 block w-full text-center py-3 px-4 rounded-xl font-medium transition-all duration-300 text-sm ${
              plan.featured
                ? 'bg-emerald-500/15 hover:bg-emerald-500/25 border border-emerald-500/25 text-emerald-400 hover:text-emerald-300'
                : 'border border-[#1a1e23] text-white hover:bg-white/5'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #plans .grid > div {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  
  #plans .grid > div.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const section = document.getElementById('plans');
  const cards = section?.querySelectorAll('.grid > div');
  
  if (cards?.length && section) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          cards.forEach((card, i) => {
            setTimeout(() => {
              card.classList.add('visible');
            }, i * 100);
          });
          observer.disconnect();
        }
      });
    }, { threshold: 0.15 });
    
    observer.observe(section);
  }
</script>