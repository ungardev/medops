---
const plans = [
  {
    name: 'Professional',
    price: '$25',
    period: '/mes',
    description: 'Control clínico individual',
    features: [
      'Consulta CIE-11',
      'Recetas digitales',
      'Historial clínico',
      'Sala de espera',
      'Dashboard básico',
    ],
    cta: 'Comenzar',
    href: 'https://app.medopz.com/',
  },
  {
    name: 'Institutional',
    price: '$120',
    period: '/mes',
    description: 'Multi-sede, quirófanos, permisos granulares',
    features: [
      'Todo Professional',
      'Multi-sede completa',
      'Gestión de quirófanos',
      'Permisos granulares',
      'API Finance',
      'Soporte 24/7',
    ],
    cta: 'Contactar',
    href: 'mailto:info.medopz@gmail.com?subject=Plan Institutional',
    featured: true,
  },
  {
    name: 'Transactional Engine',
    price: '$250',
    period: '/mes',
    description: 'Pasarelas automatizadas, conciliación BCV',
    features: [
      'Todo Institutional',
      'Mercantil P2C',
      'Banesco API',
      'Conciliación BCV',
      'API Payments',
      'SLA prioritario',
    ],
    cta: 'Consultar',
    href: 'mailto:info.medopz@gmail.com?subject=Transactional Engine',
  },
];
---

<section id="pricing" class="py-20 sm:py-24 lg:py-32 px-4 sm:px-6 relative">
  <!-- Background -->
  <div class="absolute inset-0 bg-black-surface"></div>
  
  <!-- Grid Pattern -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#10b981 1px, transparent 1px), linear-gradient(90deg, #10b981 1px, transparent 1px); background-size: 60px 60px;"></div>
  
  <div class="max-w-[1100px] mx-auto relative">
    <!-- Section Header -->
    <div class="text-center mb-12 sm:mb-16">
      <span class="text-[11px] font-medium text-accent-emerald uppercase tracking-[0.2em]">Precios</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mt-4 tracking-tight">
        Suite de Operaciones
        <span class="block text-text-secondary font-normal mt-2">para instituciones</span>
      </h2>
    </div>
    
    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {plans.map((plan, index) => (
        <div 
          class={`relative p-6 rounded-2xl transition-all duration-500 ${
            plan.featured 
              ? 'bg-black-surface border-2 border-accent-blue/30' 
              : 'bg-black-card border border-black-border'
          }`}
          style={`animation-delay: ${index * 100}ms`}
        >
          {plan.featured && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-accent-blue text-[10px] font-semibold text-black rounded-full uppercase tracking-wider">
              Recomendado
            </div>
          )}
          
          <!-- Plan Name -->
          <div class="mb-5">
            <span class="text-[11px] font-medium text-text-muted uppercase tracking-wider">{plan.name}</span>
          </div>
          
          <!-- Price -->
          <div class="flex items-baseline gap-1 mb-2">
            <span class={`text-4xl font-bold tracking-tight ${plan.featured ? 'text-accent-emerald' : 'text-white'}`}>{plan.price}</span>
            <span class="text-[13px] text-text-muted">{plan.period}</span>
          </div>
          
          <!-- Description -->
          <p class="text-[12px] text-text-muted mb-6 leading-relaxed">{plan.description}</p>
          
          <!-- Features -->
          <ul class="space-y-2.5 mb-8">
            {plan.features.map((feature) => (
              <li class="flex items-center gap-2.5">
                <div class={`w-4 h-4 rounded flex items-center justify-center shrink-0 ${plan.featured ? 'bg-accent-blue/10 border border-accent-blue/20' : 'bg-black-border'}`}>
                  <svg class={`w-2.5 h-2.5 ${plan.featured ? 'text-accent-emerald' : 'text-text-muted'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-[12px] text-text-secondary">{feature}</span>
              </li>
            ))}
          </ul>
          
          <!-- CTA -->
          <a 
            href={plan.href}
            class={`w-full inline-flex items-center justify-center gap-2 px-4 py-3 text-[12px] font-medium rounded-xl transition-all ${
              plan.featured
                ? 'bg-accent-blue/10 hover:bg-accent-blue/20 border border-accent-blue/30 text-accent-emerald hover:border-accent-blue/50'
                : 'bg-black-card hover:bg-black-surface border border-black-border text-text-secondary hover:text-white'
            }`}
          >
            {plan.cta}
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #pricing .grid > div {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  
  #pricing .grid > div.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const section = document.getElementById('pricing');
  const cards = section?.querySelectorAll('.grid > div');
  
  if (cards?.length && section) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          cards.forEach((card, i) => {
            setTimeout(() => {
              card.classList.add('visible');
            }, i * 100);
          });
          observer.disconnect();
        }
      });
    }, { threshold: 0.15 });
    
    observer.observe(section);
  }
</script>