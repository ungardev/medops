---
const portals = [
  {
    icon: 'user-check',
    label: 'DOCTOR PORTAL',
    title: 'El Centro de Operaciones del Médico',
    description: 'Todo lo que el médico especialista necesita en un solo lugar: consulta, diagnóstico, cirugías, recetas y más.',
    features: [
      'Consulta en tiempo real con CIE-11/SNOMED CT',
      'Gestión integral de cirugías (pre/intra/post-op)',
      'Historial clínico completo del paciente',
      'Sala de espera inteligente con prioridades',
      'Recetas digitales y tratamientos',
      'Dashboard financiero personal',
    ],
    status: 'Disponible',
    statusColor: 'emerald',
    loginUrl: 'http://localhost:8080/login',
  },
  {
    icon: 'heart',
    label: 'PATIENT PORTAL',
    title: 'El Primer Portal del Paciente en Venezuela',
    description: 'Empodera a tus pacientes con acceso a su expediente, citas, resultados y sala de espera en tiempo real.',
    features: [
      'Expediente médico digital completo',
      'Agendamiento de citas en línea',
      'Sala de espera con posición en cola',
      'Historial de pagos y facturas',
      'Resultados de exámenes',
      'Perfil personal con biometría',
    ],
    status: 'Disponible',
    statusColor: 'emerald',
    loginUrl: 'http://localhost:8080/patient/login',
  },
  {
    icon: 'building',
    label: 'INSTITUTION PORTAL',
    title: 'Gestión Integral de Clínicas y Hospitales',
    description: 'Administra tu institución médica con dashboards en tiempo real, gestión de camas y control multi-sede.',
    features: [
      'Dashboard operacional multi-sede',
      'Gestión de camas y pabellones',
      'Control de quirófanos y horarios',
      'Dashboard financiero institucional',
      'Gestión de RRHH médico',
      'Reportes y analíticas avanzadas',
    ],
    status: 'Próximamente',
    statusColor: 'amber',
    loginUrl: '#',
  },
];
---
<section id="portals" class="py-24 px-6">
  <div class="max-w-[1200px] mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="text-[13px] font-medium text-emerald-400/80 uppercase tracking-wider">Portales</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mt-3 tracking-tight">
        Tres Portales.
        <span class="block text-white/60 font-normal mt-1">Un Ecosistema.</span>
      </h2>
    </div>
    
    <!-- Portals -->
    <div class="space-y-6">
      {portals.map((portal) => (
        <div class="group bg-white/5 border border-white/10 rounded-lg p-6 lg:p-8 hover:border-white/20 transition-all">
          <div class="flex flex-col lg:flex-row lg:items-start gap-6">
            <!-- Left: Icon + Info -->
            <div class="lg:w-1/3">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/60">
                    {portal.icon === 'user-check' && <><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/></>}
                    {portal.icon === 'heart' && <><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></>}
                    {portal.icon === 'building' && <><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></>}
                  </svg>
                </div>
                <div>
                  <span class="text-[12px] font-medium text-white/60 uppercase tracking-wider">{portal.label}</span>
                  <span class={`ml-2 text-[11px] font-medium px-2 py-0.5 rounded border ${
                    portal.statusColor === 'emerald' 
                      ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' 
                      : 'bg-amber-500/10 text-amber-400 border-amber-500/20'
                  }`}>
                    {portal.status}
                  </span>
                </div>
              </div>
              <h3 class="text-[16px] font-semibold text-white mb-2">{portal.title}</h3>
              <p class="text-[13px] text-white/60 leading-relaxed">{portal.description}</p>
              {portal.loginUrl !== '#' && (
                <a 
                  href={portal.loginUrl}
                  class="inline-flex items-center gap-2 mt-4 px-4 py-2 bg-emerald-500/15 hover:bg-emerald-500/25 border border-emerald-500/25 text-emerald-400 text-[12px] font-medium rounded-lg transition-all"
                >
                  Acceder al Portal
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              )}
            </div>
            
            <!-- Right: Features -->
            <div class="lg:w-2/3">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {portal.features.map((feature) => (
                  <div class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-emerald-400/80 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-[13px] text-white/60">{feature}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>