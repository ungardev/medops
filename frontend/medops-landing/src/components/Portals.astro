---
const doctorPortal = {
  icon: 'usercheck',
  label: 'DOCTOR',
  title: 'Workstation Médica',
  description: 'Todo tu consultorio en una pantalla.',
  badges: ['Sala de Espera Live', 'Codificación CIE-11', 'Quirófanos', 'Wallet'],
  status: 'Disponible',
  href: 'https://app.medopz.com/',
  placeholder: 'Centro de Control Clínico',
};

const patientPortal = {
  icon: 'heart',
  label: 'PACIENTE',
  title: 'Tu Historia Clínica Digital',
  description: 'Accede a recetas, citas y pagos cuando quieras',
  badges: ['Acceso 24/7', 'Recetas Digitales', 'Mis Pagos'],
  status: 'Incluido',
  href: 'https://patient.medopz.com/',
  placeholder: 'Expediente Paciente',
};
---

<section id="portals" class="py-24 lg:py-32 px-6 bg-transparent relative">
  <div class="max-w-[1200px] mx-auto relative">
    <div class="text-center mb-20">
      <span class="text-lg md:text-xl font-bold text-emerald-400 uppercase tracking-[0.2em]">Ecosistema Operativo</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-4 tracking-tight">
        Para Doctores y Pacientes
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center mb-24 lg:mb-32">
      <div class="lg:col-span-5 order-2 lg:order-1 text-center lg:text-left">
        <div class="flex flex-col md:flex-row items-center md:items-center gap-4 mb-6">
          <div class="w-14 h-14 rounded-xl bg-[#0c0e12] border border-[#1a1e23] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" class="text-emerald-400" aria-hidden="true" role="img">
              <use href={`/icons.svg#icon-${doctorPortal.icon}`} />
            </svg>
          </div>
          <div class="text-center md:text-left">
            <span class="text-lg md:text-xl font-bold text-emerald-400 uppercase tracking-[0.15em]">{doctorPortal.label}</span>
          </div>
        </div>

        <h3 class="text-3xl md:text-4xl font-bold text-white mb-4 leading-tight">
          {doctorPortal.title}
        </h3>
        <p class="text-lg md:text-xl text-slate-200 leading-relaxed mb-8">
          {doctorPortal.description}
        </p>

        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mb-8">
          {doctorPortal.badges.map((badge) => (
            <span class="px-4 py-2 bg-[#0c0e12] border border-[#1a1e23] rounded-lg text-sm font-medium text-white">
              {badge}
            </span>
          ))}
        </div>

        <a
          href={doctorPortal.href}
          target="_blank"
          class="inline-flex items-center justify-center gap-3 px-6 py-3.5 bg-emerald-500/15 hover:bg-emerald-500/25 border border-emerald-500/30 text-emerald-400 hover:text-emerald-300 rounded-xl transition-all text-sm font-medium hover:border-emerald-500/50"
        >
          Acceder al Portal Doctor
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2">
        <div class="relative group">
          {/* Outer glow effect */}
          <div class="absolute -inset-1 bg-gradient-to-r from-emerald-500/20 via-transparent to-emerald-500/10 rounded-2xl blur-sm"></div>
          
          {/* Main container with hover scale */}
          <div class="relative bg-[#0a0b0d]/90 border border-slate-700/50 rounded-xl shadow-2xl overflow-hidden group-hover:scale-[1.01] transition-transform duration-500">
            {/* Top accent line */}
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent z-20"></div>
            
            {/* Image with Ken Burns animation */}
            <div class="relative w-full overflow-hidden">
              <img 
                src="/screenshots/doctor-portal.png" 
                alt="Doctor Portal Dashboard" 
                class="w-full h-auto object-contain"
              />
              
              {/* Gradient overlays for premium feel */}
              <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d]/40 via-transparent to-transparent pointer-events-none z-10"></div>
              <div class="absolute inset-0 bg-gradient-to-b from-[#0a0b0d]/20 via-transparent to-transparent pointer-events-none z-10"></div>
            </div>
            
            {/* Bottom accent line */}
            <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent z-20"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 order-1">
        <div class="relative group">
          {/* Outer glow effect */}
          <div class="absolute -inset-1 bg-gradient-to-r from-blue-500/20 via-transparent to-blue-500/10 rounded-2xl blur-sm"></div>
          
          {/* Main container with hover scale */}
          <div class="relative bg-[#0a0b0d]/90 border border-slate-700/50 rounded-xl shadow-2xl overflow-hidden group-hover:scale-[1.01] transition-transform duration-500">
            {/* Top accent line */}
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-500/40 to-transparent z-20"></div>
            
            {/* Image with Ken Burns animation */}
            <div class="relative w-full overflow-hidden">
              <img 
                src="/screenshots/patient-portal.png" 
                alt="Patient Portal Dashboard" 
                class="w-full h-auto object-contain"
              />
              
              {/* Gradient overlays for premium feel */}
              <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d]/40 via-transparent to-transparent pointer-events-none z-10"></div>
              <div class="absolute inset-0 bg-gradient-to-b from-[#0a0b0d]/20 via-transparent to-transparent pointer-events-none z-10"></div>
            </div>
            
            {/* Bottom accent line */}
            <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-500/40 to-transparent z-20"></div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-5 order-2 text-center lg:text-left">
        <div class="flex flex-col md:flex-row items-center md:items-center gap-4 mb-6">
          <div class="w-14 h-14 rounded-xl bg-[#0c0e12] border border-[#1a1e23] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" class="text-emerald-400" aria-hidden="true" role="img">
              <use href={`/icons.svg#icon-${patientPortal.icon}`} />
            </svg>
          </div>
          <div class="text-center md:text-left">
            <span class="text-lg md:text-xl font-bold text-emerald-400 uppercase tracking-[0.15em]">{patientPortal.label}</span>
          </div>
        </div>

        <h3 class="text-3xl md:text-4xl font-bold text-white mb-4 leading-tight">
          {patientPortal.title}
        </h3>
        <p class="text-lg md:text-xl text-slate-200 leading-relaxed mb-8">
          {patientPortal.description}
        </p>

        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mb-8">
          {patientPortal.badges.map((badge) => (
            <span class="px-4 py-2 bg-[#0c0e12] border border-[#1a1e23] rounded-lg text-sm font-medium text-white">
              {badge}
            </span>
          ))}
        </div>

        <a
          href={patientPortal.href}
          target="_blank"
          class="inline-flex items-center justify-center gap-3 px-6 py-3.5 bg-white/5 hover:bg-white/10 border border-white/15 text-white/80 hover:text-white rounded-xl transition-all text-sm font-medium hover:border-white/25"
        >
          Acceder al Portal Paciente
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>