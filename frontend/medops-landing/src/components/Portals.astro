---
const doctorPortal = {
  icon: 'usercheck',
  label: 'DOCTOR PORTAL',
  title: 'Workstation Médica',
  description: 'Todo tu consultorio en una pantalla. Sala de espera, diagnósticos, pagos.',
  badges: ['Sala de Espera Live', 'Codificación CIE-11', 'Quirófanos', 'Wallet'],
  status: 'Disponible',
  href: 'https://app.medopz.com/',
  placeholder: 'Centro de Control Clínico',
};

const patientPortal = {
  icon: 'heart',
  label: 'PATIENT PORTAL',
  title: 'Tu Historia Clínica Digital',
  description: 'Accede a tus recetas, citas y pagos desde tu celular.',
  badges: ['Acceso 24/7', 'Recetas Digitales', 'Mis Pagos'],
  status: 'Incluido',
  href: 'https://patient.medopz.com/',
  placeholder: 'Expediente Paciente',
};
---

<section id="portals" class="py-24 lg:py-32 px-6 bg-[#050608] relative">
  <div class="max-w-[1200px] mx-auto relative">
    <div class="text-center mb-20">
      <span class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em]">Ecosistema Completo</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-4 tracking-tight">
        Para Doctores y Pacientes
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center mb-24 lg:mb-32">
      <div class="lg:col-span-5 order-2 lg:order-1">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-14 h-14 rounded-xl bg-[#0c0e12] border border-[#1a1e23] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" class="text-emerald-400" aria-hidden="true" role="img">
              <use href={`/icons.svg#icon-${doctorPortal.icon}`} />
            </svg>
          </div>
          <div>
            <span class="text-xs font-bold text-emerald-400 uppercase tracking-wider">{doctorPortal.label}</span>
            <div class="flex items-center gap-2 mt-1">
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
              <span class="text-sm text-slate-300">{doctorPortal.status}</span>
            </div>
          </div>
        </div>

        <h3 class="text-3xl md:text-4xl font-bold text-white mb-4 leading-tight">
          {doctorPortal.title}
        </h3>
        <p class="text-base text-slate-200 leading-relaxed mb-8">
          {doctorPortal.description}
        </p>

        <div class="flex flex-wrap gap-3 mb-8">
          {doctorPortal.badges.map((badge) => (
            <span class="px-4 py-2 bg-[#0c0e12] border border-[#1a1e23] rounded-lg text-sm font-medium text-white">
              {badge}
            </span>
          ))}
        </div>

        <a
          href={doctorPortal.href}
          target="_blank"
          class="inline-flex items-center gap-3 px-6 py-3.5 bg-emerald-500/15 hover:bg-emerald-500/25 border border-emerald-500/30 text-emerald-400 hover:text-emerald-300 rounded-xl transition-all text-sm font-medium hover:border-emerald-500/50"
        >
          Acceder al Portal Doctor
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2">
        <div class="relative bg-[#0a0b0d]/80 border border-slate-800/80 rounded-xl shadow-2xl overflow-hidden hover:scale-[1.01] transition-transform duration-500 h-[400px] flex items-center justify-center group">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent"></div>
          <div class="text-center relative z-10">
            <div class="w-16 h-16 rounded-2xl bg-[#0c0e12] border border-[#1a1e23] flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" class="text-emerald-400/50" aria-hidden="true" role="img">
                <use href={`/icons.svg#icon-dashboard`} />
              </svg>
            </div>
            <span class="text-slate-500 text-sm font-medium block mb-2">Workstation Médica</span>
            <span class="text-slate-600 text-xs">Screenshot pronto disponible</span>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 order-1">
        <div class="relative bg-[#0a0b0d]/80 border border-slate-800/80 rounded-xl shadow-2xl overflow-hidden hover:scale-[1.01] transition-transform duration-500 h-[400px] flex items-center justify-center group">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent"></div>
          <div class="text-center relative z-10">
            <div class="w-16 h-16 rounded-2xl bg-[#0c0e12] border border-[#1a1e23] flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" class="text-emerald-400/50" aria-hidden="true" role="img">
                <use href={`/icons.svg#icon-heart`} />
              </svg>
            </div>
            <span class="text-slate-500 text-sm font-medium block mb-2">Portal Paciente</span>
            <span class="text-slate-600 text-xs">Screenshot pronto disponible</span>
          </div>
        </div>
      </div>

      <div class="lg:col-span-5 order-2">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-14 h-14 rounded-xl bg-[#0c0e12] border border-[#1a1e23] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" class="text-emerald-400" aria-hidden="true" role="img">
              <use href={`/icons.svg#icon-${patientPortal.icon}`} />
            </svg>
          </div>
          <div>
            <span class="text-xs font-bold text-emerald-400 uppercase tracking-wider">{patientPortal.label}</span>
            <div class="flex items-center gap-2 mt-1">
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
              <span class="text-sm text-slate-300">{patientPortal.status}</span>
            </div>
          </div>
        </div>

        <h3 class="text-3xl md:text-4xl font-bold text-white mb-4 leading-tight">
          {patientPortal.title}
        </h3>
        <p class="text-base text-slate-200 leading-relaxed mb-8">
          {patientPortal.description}
        </p>

        <div class="flex flex-wrap gap-3 mb-8">
          {patientPortal.badges.map((badge) => (
            <span class="px-4 py-2 bg-[#0c0e12] border border-[#1a1e23] rounded-lg text-sm font-medium text-white">
              {badge}
            </span>
          ))}
        </div>

        <a
          href={patientPortal.href}
          target="_blank"
          class="inline-flex items-center gap-3 px-6 py-3.5 bg-white/5 hover:bg-white/10 border border-white/15 text-white/80 hover:text-white rounded-xl transition-all text-sm font-medium hover:border-white/25"
        >
          Acceder al Portal Paciente
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>