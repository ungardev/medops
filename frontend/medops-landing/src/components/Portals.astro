---
const doctorPortal = {
  icon: 'user-check',
  label: 'DOCTOR PORTAL',
  title: 'Workstation Médica',
  description: 'Todo tu consultorio en una pantalla. Sala de espera, diagnósticos, pagos.',
  badges: ['Sala de Espera Live', 'Codificación CIE-11', 'Quirófanos', 'Wallet'],
  status: 'Disponible',
  href: 'https://app.medopz.com/',
  placeholder: 'Centro de Control Clínico',
};

const patientPortal = {
  icon: 'heart',
  label: 'PATIENT PORTAL',
  title: 'Tu Historia Clínica Digital',
  description: 'Accede a tus recetas, citas y pagos desde tu celular.',
  badges: ['Acceso 24/7', 'Recetas Digitales', 'Mis Pagos'],
  status: 'Incluido',
  href: 'https://patient.medopz.com/',
  placeholder: 'Expediente Paciente',
};
---

<section id="portals" class="py-24 lg:py-32 px-6 bg-[#050608] relative">
  <div class="max-w-[1200px] mx-auto relative">
    <div class="text-center mb-20">
      <span class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em]">Ecosistema Omnicanal</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-4 tracking-tight">
        Dos Portales. Una Plataforma.
      </h2>
    </div>

    <!-- Doctor Portal Block: Text Left, Image Right -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center mb-24 lg:mb-32">
      <div class="lg:col-span-5 order-2 lg:order-1">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-xl bg-[#0c0e12] border border-[#1a1e23] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <polyline points="16 11 18 13 22 9"/>
            </svg>
          </div>
          <div>
            <span class="text-[11px] font-bold text-emerald-400 uppercase tracking-wider">{doctorPortal.label}</span>
            <div class="flex items-center gap-2 mt-0.5">
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
              <span class="text-xs text-slate-400">{doctorPortal.status}</span>
            </div>
          </div>
        </div>

        <h3 class="text-2xl md:text-3xl font-bold text-white mb-4 leading-tight">
          {doctorPortal.title}
        </h3>
        <p class="text-sm text-slate-400 leading-relaxed mb-6">
          {doctorPortal.description}
        </p>

        <div class="flex flex-wrap gap-2 mb-8">
          {doctorPortal.badges.map((badge) => (
            <span class="px-3 py-1.5 bg-[#0c0e12] border border-[#1a1e23] rounded-lg text-[11px] font-medium text-slate-300">
              {badge}
            </span>
          ))}
        </div>

        <a
          href={doctorPortal.href}
          target="_blank"
          class="inline-flex items-center gap-3 px-6 py-3.5 bg-emerald-500/15 hover:bg-emerald-500/25 border border-emerald-500/30 text-emerald-400 hover:text-emerald-300 rounded-xl transition-all text-sm font-medium hover:border-emerald-500/50"
        >
          Acceder al Portal Doctor
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2">
        <div class="bg-[#0a0b0d]/80 border border-slate-800/80 rounded-xl shadow-2xl overflow-hidden hover:scale-[1.01] transition-transform duration-500 h-[350px] flex items-center justify-center">
          <div class="text-center">
            <span class="text-slate-500 text-sm font-mono tracking-wide block mb-2">[ Workstation Médica ]</span>
            <span class="text-slate-600 text-xs">Screenshot: {doctorPortal.placeholder}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Patient Portal Block: Image Left, Text Right -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 order-1">
        <div class="bg-[#0a0b0d]/80 border border-slate-800/80 rounded-xl shadow-2xl overflow-hidden hover:scale-[1.01] transition-transform duration-500 h-[350px] flex items-center justify-center">
          <div class="text-center">
            <span class="text-slate-500 text-sm font-mono tracking-wide block mb-2">[ Portal Paciente Mobile ]</span>
            <span class="text-slate-600 text-xs">Screenshot: {patientPortal.placeholder}</span>
          </div>
        </div>
      </div>

      <div class="lg:col-span-5 order-2">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-xl bg-[#0c0e12] border border-[#1a1e23] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
            </svg>
          </div>
          <div>
            <span class="text-[11px] font-bold text-emerald-400 uppercase tracking-wider">{patientPortal.label}</span>
            <div class="flex items-center gap-2 mt-0.5">
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
              <span class="text-xs text-slate-400">{patientPortal.status}</span>
            </div>
          </div>
        </div>

        <h3 class="text-2xl md:text-3xl font-bold text-white mb-4 leading-tight">
          {patientPortal.title}
        </h3>
        <p class="text-sm text-slate-400 leading-relaxed mb-6">
          {patientPortal.description}
        </p>

        <div class="flex flex-wrap gap-2 mb-8">
          {patientPortal.badges.map((badge) => (
            <span class="px-3 py-1.5 bg-[#0c0e12] border border-[#1a1e23] rounded-lg text-[11px] font-medium text-slate-300">
              {badge}
            </span>
          ))}
        </div>

        <a
          href={patientPortal.href}
          target="_blank"
          class="inline-flex items-center gap-3 px-6 py-3.5 bg-white/5 hover:bg-white/10 border border-white/15 text-white/80 hover:text-white rounded-xl transition-all text-sm font-medium hover:border-white/25"
        >
          Acceder al Portal Paciente
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>