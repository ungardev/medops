---
const links = {
  producto: [
    { href: '#features', label: 'Features' },
    { href: '#portals', label: 'Portales' },
    { href: '#pricing', label: 'Precios' },
  ],
  portales: [
    { href: 'http://localhost:8080/login', label: 'Portal Doctor' },
    { href: 'http://localhost:8080/patient/login', label: 'Portal Paciente' },
  ],
  empresa: [
    { href: '#', label: 'Sobre Nosotros' },
    { href: '#', label: 'Blog' },
    { href: '#contact', label: 'Contacto' },
  ],
  legal: [
    { href: '#', label: 'Privacidad' },
    { href: '#', label: 'Términos' },
    { href: '#', label: 'HIPAA' },
  ],
};
---
<footer class="border-t border-white/5 py-12 px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 mb-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <img src="/medopz_logo_blanco_solo.svg" alt="MEDOPZ" class="h-7 w-7" />
          <img src="/medopz_fuente_blanco.svg" alt="MEDOPZ" class="h-[12px] w-auto opacity-80" />
        </div>
        <p class="text-[11px] text-white/50 leading-relaxed">
          La plataforma de gestión médica más potente de Venezuela.
        </p>
      </div>
      
      <!-- Links -->
      <div>
        <h4 class="text-[11px] font-medium text-white/60 uppercase tracking-wider mb-3">Producto</h4>
        <ul class="space-y-2">
          {links.producto.map((link) => (
            <li><a href={link.href} class="text-[12px] text-white/50 hover:text-white/70 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="text-[11px] font-medium text-white/60 uppercase tracking-wider mb-3">Portales</h4>
        <ul class="space-y-2">
          {links.portales.map((link) => (
            <li><a href={link.href} class="text-[12px] text-white/50 hover:text-white/70 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="text-[11px] font-medium text-white/60 uppercase tracking-wider mb-3">Empresa</h4>
        <ul class="space-y-2">
          {links.empresa.map((link) => (
            <li><a href={link.href} class="text-[12px] text-white/50 hover:text-white/70 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="text-[11px] font-medium text-white/60 uppercase tracking-wider mb-3">Legal</h4>
        <ul class="space-y-2">
          {links.legal.map((link) => (
            <li><a href={link.href} class="text-[12px] text-white/50 hover:text-white/70 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    
    <!-- Bottom -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-white/5">
      <p class="text-[11px] text-white/40">
        © {new Date().getFullYear()} MEDOPZ. Todos los derechos reservados.
      </p>
      <p class="text-[11px] text-white/40">
        Hecho con ❤️ en Venezuela 🇻🇪
      </p>
    </div>
  </div>
</footer>