---
const links = {
  producto: [
    { href: '#features', label: 'Features' },
    { href: '#portals', label: 'Portales' },
    { href: '#pricing', label: 'Planes' },
  ],
  portales: [
    { href: 'http://localhost:8080/login', label: 'Portal Doctor' },
    { href: 'http://localhost:8080/patient/login', label: 'Portal Paciente' },
  ],
  empresa: [
    { href: '#contact', label: 'Contacto' },
    { href: '#', label: 'Blog' },
  ],
  legal: [
    { href: '#', label: 'Privacidad' },
    { href: '#', label: 'Términos' },
    { href: '#', label: 'HIPAA' },
  ],
};
---

<footer class="border-t border-white/10 py-12 px-6">
  <div class="max-w-[1200px] mx-auto">
    <!-- Links Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Producto -->
      <div class="group">
        <h4 class="text-[11px] font-medium text-white/60 uppercase tracking-wider mb-4">Producto</h4>
        <ul class="space-y-3">
          {links.producto.map((link) => (
            <li><a href={link.href} class="text-[13px] text-white/50 hover:text-emerald-400 transition-all duration-300 hover:drop-shadow-[0_0_8px_rgba(16,185,129,0.4)]">{link.label}</a></li>
          ))}
        </ul>
      </div>
      
      <!-- Portales -->
      <div class="group">
        <h4 class="text-[11px] font-medium text-white/60 uppercase tracking-wider mb-4">Portales</h4>
        <ul class="space-y-3">
          {links.portales.map((link) => (
            <li><a href={link.href} class="text-[13px] text-white/50 hover:text-emerald-400 transition-all duration-300 hover:drop-shadow-[0_0_8px_rgba(16,185,129,0.4)]">{link.label}</a></li>
          ))}
        </ul>
      </div>
      
      <!-- Empresa -->
      <div class="group">
        <h4 class="text-[11px] font-medium text-white/60 uppercase tracking-wider mb-4">Empresa</h4>
        <ul class="space-y-3">
          {links.empresa.map((link) => (
            <li><a href={link.href} class="text-[13px] text-white/50 hover:text-emerald-400 transition-all duration-300 hover:drop-shadow-[0_0_8px_rgba(16,185,129,0.4)]">{link.label}</a></li>
          ))}
        </ul>
      </div>
      
      <!-- Legal -->
      <div class="group">
        <h4 class="text-[11px] font-medium text-white/60 uppercase tracking-wider mb-4">Legal</h4>
        <ul class="space-y-3">
          {links.legal.map((link) => (
            <li><a href={link.href} class="text-[13px] text-white/50 hover:text-emerald-400 transition-all duration-300 hover:drop-shadow-[0_0_8px_rgba(16,185,129,0.4)]">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    
    <!-- Bottom -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-white/10">
      <!-- Brand -->
      <a href="/" class="flex items-center gap-3 group">
        <img src="/medopz_logo_blanco_solo.svg" alt="MEDOPZ" class="h-8 w-8 transition-all duration-300 group-hover:drop-shadow-[0_0_12px_rgba(16,185,129,0.5)]" />
        <img src="/medopz_fuente_blanco.svg" alt="MEDOPZ" class="h-[14px] w-auto opacity-60 group-hover:opacity-80 transition-all duration-300" />
      </a>
      
      <!-- Copyright -->
      <div class="flex items-center gap-4">
        <p class="text-[12px] text-white/40">
          © {new Date().getFullYear()} MEDOPZ.
        </p>
        <p class="text-[12px] text-white/40 hidden sm:block">
          Hecho con ❤️ en Venezuela
        </p>
      </div>
    </div>
  </div>
</footer>