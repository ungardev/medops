---
const links = {
  producto: [
    { href: '#features', label: 'Infraestructura' },
    { href: '#portals', label: 'Portales' },
    { href: '#pricing', label: 'Licenciamiento' },
  ],
  portales: [
    { href: 'https://app.medopz.com/', label: 'Portal Doctor' },
    { href: 'https://patient.medopz.com/', label: 'Portal Paciente' },
  ],
  empresa: [
    { href: '#contact', label: 'Contacto' },
    { href: '#', label: 'Blog' },
  ],
  legal: [
    { href: '#', label: 'Privacidad' },
    { href: '#', label: 'Términos' },
    { href: '#', label: 'HIPAA' },
  ],
};
---

<footer class="border-t border-[#1a1e23] py-12 px-6 bg-[#050608]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Links Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Producto -->
      <div>
        <h4 class="text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-4">Producto</h4>
        <ul class="space-y-3">
          {links.producto.map((link) => (
            <li><a href={link.href} class="text-sm text-slate-300 hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      
      <!-- Portales -->
      <div>
        <h4 class="text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-4">Portales</h4>
        <ul class="space-y-3">
          {links.portales.map((link) => (
            <li><a href={link.href} class="text-sm text-slate-300 hover:text-[#10b981] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      
      <!-- Empresa -->
      <div>
        <h4 class="text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-4">Empresa</h4>
        <ul class="space-y-3">
          {links.empresa.map((link) => (
            <li><a href={link.href} class="text-sm text-slate-300 hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      
      <!-- Legal -->
      <div>
        <h4 class="text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-4">Legal</h4>
        <ul class="space-y-3">
          {links.legal.map((link) => (
            <li><a href={link.href} class="text-sm text-slate-300 hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    
    <!-- Bottom -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-[#1a1e23]">
      <!-- Brand -->
      <a href="/" class="flex items-center gap-3">
        <img src="/medopz_logo_blanco_solo.svg" alt="MEDOPZ" class="h-8 w-8" />
        <img src="/medopz_fuente_blanco.svg" alt="MEDOPZ" class="h-[14px] w-auto opacity-60" />
      </a>
      
      <!-- Copyright -->
      <div class="flex items-center gap-4">
        <p class="text-sm text-slate-500">
          © {new Date().getFullYear()} MEDOPZ.
        </p>
        <p class="text-sm text-slate-500 hidden sm:block">
          Hecho en Venezuela
        </p>
      </div>
    </div>
  </div>
</footer>