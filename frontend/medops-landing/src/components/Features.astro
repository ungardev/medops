---
const pillars = [
  {
    icon: 'fintech',
    label: 'FINTECH ENGINE',
    title: 'Pago Móvil + Bimonetario',
    description: 'Infraestructura financiera integrada para Venezuela',
    features: [
      { label: 'Mercantil P2C', desc: 'Pagos instantáneos' },
      { label: 'Banesco API', desc: 'Integración bancaria' },
      { label: 'BCV Rate', desc: 'Tasa oficial en tiempo real' },
      { label: 'USDT Crypto', desc: 'Activos digitales' },
    ],
  },
  {
    icon: 'legal',
    label: 'LEGAL & COMPLIANCE',
    title: 'MPPS + Colegiado ID',
    description: 'Verificación institucional y sellado digital',
    features: [
      { label: 'MPPS Verification', desc: 'Licencia sanitaria' },
      { label: 'Colegiado ID', desc: 'Documento profesional' },
      { label: 'Sellado Digital', desc: 'Certificación criptográfica' },
      { label: 'INHRR Catalog', desc: 'Registro nacional' },
    ],
  },
  {
    icon: 'clinical',
    label: 'CLINICAL INTELLIGENCE',
    title: 'ICD-11 + SNOMED CT',
    description: 'Estándares internacionales de diagnóstico',
    features: [
      { label: 'ICD-11 WHO', desc: 'Clasificación oficial' },
      { label: 'SNOMED CT', desc: 'Terminología clínica' },
      { label: 'CIE-11 Search', desc: 'Búsqueda inteligente' },
      { label: 'Coding Engine', desc: 'Sugerencia automática' },
    ],
  },
];
---

<section id="features" class="py-20 sm:py-24 lg:py-32 px-4 sm:px-6 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-black"></div>
  
  <!-- Grid Pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#10b981 1px, transparent 1px), linear-gradient(90deg, #10b981 1px, transparent 1px); background-size: 80px 80px;"></div>
  
  <div class="max-w-[1200px] mx-auto relative">
    <!-- Section Header -->
    <div class="text-center mb-12 sm:mb-16">
      <span class="text-[11px] font-medium text-accent-emerald uppercase tracking-[0.2em]">Arquitectura</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mt-4 tracking-tight">
        Tres Pilares Corporativos
        <span class="block text-text-secondary font-normal mt-2">de la próxima generación</span>
      </h2>
    </div>
    
    <!-- Bento Grid - 3 Pillars -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
      {pillars.map((pillar, index) => (
        <div class="group relative p-6 lg:p-8 rounded-2xl bg-black-surface border border-black-border transition-all duration-500 hover:border-accent-blue/20">
          <!-- Accent Line Top -->
          <div class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-accent-blue/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-black-card border border-black-border flex items-center justify-center mb-6 transition-all duration-300 group-hover:border-accent-blue/30 group-hover:shadow-[0_0_15px_rgba(56,161,255,0.1)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary group-hover:text-accent-emerald transition-colors">
              {pillar.icon === 'fintech' && <><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/><path d="M6 15h4"/></>}
              {pillar.icon === 'legal' && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></>}
              {pillar.icon === 'clinical' && <><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><circle cx="20" cy="10" r="2"/></>}
            </svg>
          </div>
          
          <!-- Label -->
          <span class="text-[10px] font-semibold text-accent-emerald uppercase tracking-wider mb-2 block">{pillar.label}</span>
          
          <!-- Title -->
          <h3 class="text-xl font-semibold text-white mb-2">{pillar.title}</h3>
          
          <!-- Description -->
          <p class="text-[13px] text-text-muted mb-6 leading-relaxed">{pillar.description}</p>
          
          <!-- Features Grid -->
          <div class="grid grid-cols-2 gap-3">
            {pillar.features.map((feature) => (
              <div class="p-3 rounded-lg bg-black-card border border-black-border">
                <div class="text-[12px] font-medium text-white mb-0.5">{feature.label}</div>
                <div class="text-[10px] text-text-muted">{feature.desc}</div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #features .group {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  
  #features .group.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const section = document.getElementById('features');
  const cards = section?.querySelectorAll('.group');
  
  if (cards?.length && section) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          cards.forEach((card, i) => {
            setTimeout(() => {
              card.classList.add('visible');
            }, i * 100);
          });
          observer.disconnect();
        }
      });
    }, { threshold: 0.15 });
    
    observer.observe(section);
  }
</script>