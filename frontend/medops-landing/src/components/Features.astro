---
const features = [
  {
    icon: 'stethoscope',
    title: 'ICD-11 + SNOMED',
    description: 'Diagnósticos internacionales con estándares WHO. Expediente estructurado.',
    size: 'large',
  },
  {
    icon: 'scissors',
    title: 'Cirugía',
    description: 'Pre-intra-postoperatorio. Clasificación ASA, riesgos quirúrgicos.',
    size: 'large',
  },
  {
    icon: 'bed',
    title: 'Hospitalización',
    description: 'Gestión de cama. Admisión, evolución y alta clínica.',
    size: 'small',
  },
  {
    icon: 'brain',
    title: 'Paciente Portal',
    description: 'Tu paciente accede a su expediente, citas y resultados.',
    size: 'small',
  },
  {
    icon: 'clock',
    title: 'Sala de Espera Live',
    description: 'Cola en tiempo real.',
    size: 'small',
  },
  {
    icon: 'credit-card',
    title: 'Pagos P2C',
    description: 'Pago móvil, Zelle, cripto. Conciliación BCV.',
    size: 'small',
  },
];
---

<section id="features" class="py-32 px-4 sm:px-6 relative overflow-hidden">
  <!-- Background Effects -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-[120px]"></div>
    <div class="absolute top-1/2 right-1/4 translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-cyan-500/5 rounded-full blur-[100px]"></div>
  </div>
  
  <div class="max-w-[1200px] mx-auto relative">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <span class="text-[12px] font-medium text-emerald-400/80 uppercase tracking-[0.2em]">Features</span>
      <h2 class="text-4xl sm:text-5xl font-bold text-white mt-4 tracking-tight">
        Potencia Operativa de Salud
        <span class="block text-white/50 font-normal mt-2">Abarca todos los frentes</span>
      </h2>
    </div>
    
    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 auto-rows-[140px]">
      {features.map((feature, index) => (
        <div 
          class={`group relative overflow-hidden rounded-2xl p-6 transition-all duration-500 ease-out ${
            feature.size === 'large' 
              ? 'col-span-1 md:col-span-2 row-span-2' 
              : 'col-span-1 row-span-1'
          }`}
          style={`animation-delay: ${index * 100}ms`}
        >
          <!-- Glassmorphism Background -->
          <div class="absolute inset-0 bg-gradient-to-br from-white/[0.08] to-white/[0.02] backdrop-blur-xl rounded-2xl border border-white/[0.08] transition-all duration-500 group-hover:border-white/[0.2] group-hover:from-white/[0.12]"></div>
          
          <!-- Inner Shadow -->
          <div class="absolute inset-0 rounded-2xl shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05)] transition-all duration-500 group-hover:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.1)]"></div>
          
          <!-- Glow Effects -->
          <div class="absolute inset-0 rounded-2xl opacity-0 transition-all duration-700 group-hover:opacity-100" style="background: radial-gradient(circle at 50% 0%, rgba(16, 185, 129, 0.15) 0%, transparent 60%);"></div>
          <div class="absolute -bottom-20 -right-20 w-40 h-40 bg-emerald-500/10 rounded-full blur-[40px] opacity-0 transition-all duration-700 group-hover:opacity-100"></div>
          
          <!-- Content -->
          <div class="relative z-10 h-full flex flex-col">
            <!-- Icon with Glow -->
            <div class="w-12 h-12 rounded-xl bg-white/[0.05] border border-white/10 flex items-center justify-center mb-auto mt-2 transition-all duration-300 group-hover:bg-white/[0.1] group-hover:border-emerald-500/30 group-hover:shadow-[0_0_20px_rgba(16,185,129,0.2)]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/60 group-hover:text-emerald-400 transition-all duration-300 group-hover:drop-shadow-[0_0_8px_rgba(16,185,129,0.5)]">
                {feature.icon === 'stethoscope' && <><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><circle cx="20" cy="10" r="2"/></>}
                {feature.icon === 'scissors' && <><circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/></>}
                {feature.icon === 'bed' && <><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></>}
                {feature.icon === 'brain' && <><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .526 4.975L3 18V6a2 2 0 0 1 2-2h1a4 4 0 0 1 4-4z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.526 4.975L21 18V6a2 2 0 0 0-2-2h-1a4 4 0 0 0-4-4z"/><path d="M12 5v13"/></>}
                {feature.icon === 'clock' && <><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></>}
                {feature.icon === 'credit-card' && <><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></>}
              </svg>
            </div>
            
            <!-- Text -->
            <div class="mt-auto">
              <h3 class="text-lg font-semibold text-white mb-1 group-hover:text-white transition-colors">{feature.title}</h3>
              <p class="text-sm text-white/50 leading-relaxed group-hover:text-white/70 transition-colors">{feature.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #features > div > .grid > div {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  
  #features > div > .grid > div.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const section = document.getElementById('features');
  const cards = section?.querySelectorAll('#features > div > .grid > div');
  
  if (cards?.length && section) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          cards.forEach((card, i) => {
            setTimeout(() => {
              card.classList.add('visible');
            }, i * 100);
          });
          observer.disconnect();
        }
      });
    }, { threshold: 0.2 });
    
    observer.observe(section);
  }
</script>