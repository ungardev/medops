---
const features = [
  {
    icon: 'stethoscope',
    title: 'CIE-11 + SNOMED',
    description: 'Diagnósticos internacionales. Expediente estructurado con estándares WHO.',
  },
  {
    icon: 'scissors',
    title: 'Cirugía',
    description: 'Pre-intra-postoperatorio. Clasificación ASA, riesgos quirúrgicos.',
  },
  {
    icon: 'bed',
    title: 'Hospitalización',
    description: 'Gestión de cama. Admisión, evolución y alta clínica.',
  },
  {
    icon: 'brain',
    title: 'Paciente Portal',
    description: 'Tu paciente accede a su expediente, citas y resultados.',
  },
  {
    icon: 'clock',
    title: 'Sala de Espera Live',
    description: 'Cola en tiempo real. El paciente ve su turno desde su celular.',
  },
  {
    icon: 'credit-card',
    title: 'Pagos P2C',
    description: 'Pago móvil, Zelle, cripto. Conciliación automática BCV.',
  },
];
---
<section id="features" class="py-24 px-6">
  <div class="max-w-[1200px] mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="text-[13px] font-medium text-emerald-400/80 uppercase tracking-wider">Funciones</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mt-3 tracking-tight">
        Todo lo que necesitas
        <span class="block text-white/60 font-normal mt-1">para tu consultorio.</span>
      </h2>
    </div>
    
    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((feature) => (
        <div class="group bg-white/5 border border-white/10 rounded-lg p-6 hover:border-white/20 transition-all">
          <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center mb-4 group-hover:border-emerald-500/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/60 group-hover:text-emerald-400 transition-colors">
              {feature.icon === 'stethoscope' && <><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><circle cx="20" cy="10" r="2"/></>}
              {feature.icon === 'scissors' && <><circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/></>}
              {feature.icon === 'bed' && <><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></>}
              {feature.icon === 'brain' && <><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .526 4.975L3 18V6a2 2 0 0 1 2-2h1a4 4 0 0 1 4-4z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.526 4.975L21 18V6a2 2 0 0 0-2-2h-1a4 4 0 0 0-4-4z"/><path d="M12 5v13"/></>}
              {feature.icon === 'clock' && <><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></>}
              {feature.icon === 'credit-card' && <><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></>}
            </svg>
          </div>
          <h3 class="text-[15px] font-semibold text-white mb-2">{feature.title}</h3>
          <p class="text-[13px] text-white/60 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>