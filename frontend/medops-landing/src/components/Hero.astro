---
const features = [
  { id: 'cie11', label: 'CIE-11 WHO', img: '/screenshots/cie11.svg' },
  { id: 'cirugia', label: 'Cirugía', img: '/screenshots/cirugia.svg' },
  { id: 'hospi', label: 'Hospitalización', img: '/screenshots/hospi.svg' },
  { id: 'sala', label: 'Sala Live', img: '/screenshots/sala.svg' },
  { id: 'pagos', label: 'Pagos P2C', img: '/screenshots/pagos.svg' },
  { id: 'sede', label: 'Multi-sede', img: '/screenshots/sede.svg' },
];
---

<section class="relative min-h-[70vh] sm:min-h-screen flex flex-col justify-start overflow-hidden pt-20 sm:pt-28">
  <!-- Background Effects - Dual glow with animation -->
  <div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] via-transparent to-transparent"></div>
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-emerald-500/5 rounded-full blur-[120px] animate-pulse-slow"></div>
  <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[300px] bg-cyan-500/3 rounded-full blur-[100px] animate-pulse-slow" style="animation-delay: 1s;"></div>
  
  <div class="relative z-10 max-w-[1000px] mx-auto px-6 text-center">
    <!-- MEDOPZ Logo - con subtle glow animation -->
    <div class="relative inline-block mb-4">
      <img src="/medopz_fuente_blanco.svg" alt="MEDOPZ" class="w-full max-w-[280px] mx-auto transition-all duration-300" />
      <div class="absolute inset-0 w-full max-w-[280px] mx-auto h-full bg-emerald-500/10 rounded-full blur-[30px] opacity-0 transition-opacity duration-700 hover:opacity-100 -z-10 left-1/2 -translate-x-1/2"></div>
    </div>
    
    <!-- Subtitle - tipografía refinada -->
    <h1 class="text-base sm:text-lg font-light text-white tracking-wide mb-2">
      Workstation elite para médicos especialistas, pacientes e instituciones de Venezuela
    </h1>
    
    <!-- Carousel Container con glow -->
    <div class="relative mt-6 mb-4">
      <!-- Left Arrow -->
      <button id="prevBtn" class="absolute left-0 top-1/2 -translate-y-1/2 z-20 w-8 h-8 sm:w-10 sm:h-10 flex items-center justify-center bg-white/[0.05] hover:bg-white/[0.12] border border-white/[0.1] hover:border-emerald-500/30 rounded-full text-white/60 hover:text-emerald-400 transition-all duration-300 hover:shadow-[0_0_20px_rgba(16,185,129,0.2)] group" aria-label="Anterior">
        <svg class="w-4 h-4 sm:w-5 sm:h-5 transition-transform duration-300 group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      
      <!-- Screenshot Area - con inner glow y transición -->
      <div id="screenshotArea" class="w-full aspect-video bg-gradient-to-br from-white/[0.06] to-white/[0.02] backdrop-blur-xl border border-white/[0.08] rounded-2xl overflow-hidden shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05),inset_0_0_80px_rgba(16,185,129,0.03)]">
        <div id="screenshotContent" class="w-full h-full flex items-center justify-center transition-all duration-500">
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-white/[0.05] border border-white/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-emerald-400/50">
                <path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><circle cx="20" cy="10" r="2"/>
              </svg>
            </div>
            <p class="text-white/40 text-sm font-medium">Screenshot: <span id="screenshotLabel">CIE-11 WHO</span></p>
          </div>
        </div>
      </div>
      
      <!-- Right Arrow -->
      <button id="nextBtn" class="absolute right-0 top-1/2 -translate-y-1/2 z-20 w-8 h-8 sm:w-10 sm:h-10 flex items-center justify-center bg-white/[0.05] hover:bg-white/[0.12] border border-white/[0.1] hover:border-emerald-500/30 rounded-full text-white/60 hover:text-emerald-400 transition-all duration-300 hover:shadow-[0_0_20px_rgba(16,185,129,0.2)] group" aria-label="Siguiente">
        <svg class="w-4 h-4 sm:w-5 sm:h-5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
    
    <!-- Feature Pills - estilo bento -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-6">
      {features.map((feature, index) => (
        <button 
          data-index={index}
          class="feature-tab px-3 sm:px-5 py-2 sm:py-2.5 bg-white/[0.08] border border-white/[0.1] rounded-xl text-[11px] sm:text-[12px] font-normal text-white/70 whitespace-nowrap hover:bg-white/[0.12] hover:border-white/[0.2] hover:text-white transition-all"
        >
          {feature.label}
        </button>
      ))}
    </div>
    
    <!-- Dot indicators -->
    <div class="flex items-center justify-center gap-1.5">
      {features.map((_, index) => (
        <button 
          data-dot={index}
          class="dot-indicator w-2 h-2 rounded-full bg-white/20 hover:bg-white/40 transition-all duration-300"
          aria-label={`Ir a ${features[index].label}`}
        />
      ))}
    </div>
  </div>
</section>

<script>
  const features = [
    { id: 'cie11', label: 'CIE-11 WHO', img: '/screenshots/cie11.svg' },
    { id: 'cirugia', label: 'Cirugía', img: '/screenshots/cirugia.svg' },
    { id: 'hospi', label: 'Hospitalización', img: '/screenshots/hospi.svg' },
    { id: 'sala', label: 'Sala Live', img: '/screenshots/sala.svg' },
    { id: 'pagos', label: 'Pagos P2C', img: '/screenshots/pagos.svg' },
    { id: 'sede', label: 'Multi-sede', img: '/screenshots/sede.svg' },
  ];
  
  let currentIndex = 0;
  const screenshotContent = document.getElementById('screenshotContent');
  const screenshotLabel = document.getElementById('screenshotLabel');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const tabs = document.querySelectorAll('.feature-tab');
  const dots = document.querySelectorAll('.dot-indicator');
  
  function updateScreenshot(index) {
    currentIndex = index;
    
    // Animate out
    if (screenshotContent) {
      screenshotContent.style.opacity = '0';
      screenshotContent.style.transform = 'translateY(10px)';
    }
    
    setTimeout(() => {
      if (screenshotLabel) {
        screenshotLabel.textContent = features[index].label;
      }
      
      // Animate in
      if (screenshotContent) {
        screenshotContent.style.opacity = '1';
        screenshotContent.style.transform = 'translateY(0)';
      }
    }, 200);
    
    tabs.forEach((tab, i) => {
      if (i === index) {
        tab.classList.remove('bg-white/[0.08]', 'border-white/[0.1]', 'text-white/70');
        tab.classList.add('bg-emerald-500/20', 'border-emerald-500/30', 'text-emerald-400');
      } else {
        tab.classList.remove('bg-emerald-500/20', 'border-emerald-500/30', 'text-emerald-400');
        tab.classList.add('bg-white/[0.08]', 'border-white/[0.1]', 'text-white/70');
      }
    });
    
    dots.forEach((dot, i) => {
      if (i === index) {
        dot.classList.remove('bg-white/20');
        dot.classList.add('bg-emerald-400', 'w-3');
      } else {
        dot.classList.remove('bg-emerald-400', 'w-3');
        dot.classList.add('bg-white/20');
      }
    });
  }
  
  tabs.forEach((tab, index) => {
    tab.addEventListener('click', () => updateScreenshot(index));
  });
  
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => updateScreenshot(index));
  });
  
  prevBtn.addEventListener('click', () => {
    const newIndex = currentIndex === 0 ? features.length - 1 : currentIndex - 1;
    updateScreenshot(newIndex);
  });
  
  nextBtn.addEventListener('click', () => {
    const newIndex = currentIndex === features.length - 1 ? 0 : currentIndex + 1;
    updateScreenshot(newIndex);
  });
  
  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') {
      const newIndex = currentIndex === 0 ? features.length - 1 : currentIndex - 1;
      updateScreenshot(newIndex);
    } else if (e.key === 'ArrowRight') {
      const newIndex = currentIndex === features.length - 1 ? 0 : currentIndex + 1;
      updateScreenshot(newIndex);
    }
  });
  
  // Auto-advance carousel every 5 seconds
  setInterval(() => {
    const newIndex = currentIndex === features.length - 1 ? 0 : currentIndex + 1;
    updateScreenshot(newIndex);
  }, 5000);
  
  updateScreenshot(0);
</script>

<style>
  @keyframes pulse-slow {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05); }
  }
  
  .animate-pulse-slow {
    animation: pulse-slow 4s ease-in-out infinite;
  }
</style>