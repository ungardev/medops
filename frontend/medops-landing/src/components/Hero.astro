---
const stats = [
  { value: '63+', label: 'Módulos Clínicos' },
  { value: 'ICD-11', label: 'Estándar WHO' },
  { value: 'Bimonetario', label: 'Ecosistema Transaccional' },
];

const features = [
  { label: 'CIE-11 WHO' },
  { label: 'SNOMED CT' },
  { label: 'Cirugía' },
  { label: 'Hospitalización' },
  { label: 'Pagos P2C' },
  { label: 'Multi-sede' },
];
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-24">
  <!-- Grid Lines Background - 1px accent emerald -->
  <div class="absolute inset-0 opacity-[0.03]">
    <div class="absolute inset-0" style="background-image: linear-gradient(#10b981 1px, transparent 1px), linear-gradient(90deg, #10b981 1px, transparent 1px); background-size: 60px 60px;"></div>
  </div>
  
  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-black via-transparent to-black"></div>
  
  <div class="relative z-10 max-w-[1000px] mx-auto px-6 text-center">
    <!-- Label -->
    <div class="inline-flex items-center gap-2 px-4 py-2 border border-black-border rounded-full mb-8">
      <span class="w-2 h-2 rounded-full bg-accent-emerald animate-pulse"></span>
      <span class="text-[11px] font-medium text-text-secondary uppercase tracking-wider">Platforma HealthTech de Venezuela</span>
    </div>
    
    <!-- Logo -->
    <div class="mb-6">
      <img src="/medopz_fuente_blanco.svg" alt="MEDOPZ" class="w-full max-w-[260px] mx-auto" />
    </div>
    
    <!-- Main Headline -->
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white tracking-tight leading-tight mb-4">
      El Command Center
      <span class="block text-accent-emerald">Clínico y Transaccional</span>
      de la Próxima Generación
    </h1>
    
    <!-- Subtitle -->
    <p class="text-base sm:text-lg text-text-secondary max-w-[600px] mx-auto mb-10">
      Workstation elite para médicos especialistas, pacientes e instituciones de Venezuela
    </p>
    
    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a 
        href="https://app.medopz.com/" 
        target="_blank"
        class="group w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 border border-accent-emerald/30 hover:border-accent-emerald/60 bg-accent-emerald/5 hover:bg-accent-emerald/10 text-accent-emerald text-[13px] font-medium rounded-xl transition-all hover:shadow-[0_0_20px_rgba(16,185,129,0.15)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/>
        </svg>
        Portal Doctor
        <span class="text-white/40 group-hover:text-accent-emerald/60 ml-1">→</span>
      </a>
      <a 
        href="https://patient.medopz.com/" 
        target="_blank"
        class="group w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 border border-white/10 hover:border-white/20 bg-white/5 hover:bg-white/10 text-white/80 hover:text-white text-[13px] font-medium rounded-xl transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
        </svg>
        Portal Paciente
        <span class="text-white/40 group-hover:text-white/60 ml-1">→</span>
      </a>
    </div>
    
    <!-- Feature Pills -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-12">
      {features.map((feature) => (
        <span class="px-3 py-1.5 bg-black-surface border border-black-border rounded-lg text-[11px] font-medium text-text-secondary">
          {feature.label}
        </span>
      ))}
    </div>
    
    <!-- Stats Row -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-[700px] mx-auto">
      {stats.map((stat, index) => (
        <div class="relative p-4 rounded-xl bg-black-card border border-black-border">
          <div class="text-2xl sm:text-3xl font-bold text-white mb-1">{stat.value}</div>
          <div class="text-[11px] font-medium text-text-muted uppercase tracking-wider">{stat.label}</div>
          {index < stats.length - 1 && (
            <div class="hidden sm:block absolute -right-2 top-1/2 -translate-y-1/2 w-4 h-4 border-r border-t border-black-border rotate-45"></div>
          )}
        </div>
      ))}
    </div>
  </div>
  
  <!-- Bottom Fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-black to-transparent"></div>
</section>

<style>
  @keyframes pulse-slow {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  
  .animate-pulse-slow {
    animation: pulse-slow 2s ease-in-out infinite;
  }
</style>