---
const features = [
  'Consulta Inteligente',
  'Cirugía Integral',
  'Hospitalización Completa',
  'Diagnóstico AI',
  'Sala de Espera Live',
  'Pagos Multi-Método',
];
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] via-transparent to-transparent"></div>
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-[120px]"></div>
  
  <div class="relative z-10 max-w-[900px] mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
      <span class="text-[10px] font-medium text-white/60 uppercase tracking-wider">Plataforma Elite de Gestión Médica</span>
    </div>
    
    <!-- Title -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white tracking-tight leading-[1.1] mb-6">
      La Plataforma de Gestión
      <span class="block text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400">
        Médica más Potente
      </span>
      de Venezuela
    </h1>
    
    <!-- Subtitle -->
    <p class="text-lg text-white/40 max-w-2xl mx-auto mb-10 leading-relaxed">
      Consulta, Cirugía, Hospitalización, Diagnóstico con AI y más. 
      Todo en un ecosistema diseñado para el médico especialista venezolano.
    </p>
    
    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a 
        href="#contact"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3 bg-emerald-500/15 hover:bg-emerald-500/25 border border-emerald-500/25 text-emerald-400 text-[12px] font-medium rounded-lg transition-all"
      >
        Solicitar Demo Gratuito
      </a>
      <a 
        href="#features"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3 bg-white/5 hover:bg-white/10 border border-white/15 text-white/70 text-[12px] font-medium rounded-lg transition-all"
      >
        Ver Producto
      </a>
    </div>
    
    <!-- Feature Pills -->
    <div class="flex flex-wrap items-center justify-center gap-3">
      {features.map((feature) => (
        <span class="px-3 py-1.5 bg-white/5 border border-white/10 rounded-lg text-[10px] font-medium text-white/40">
          {feature}
        </span>
      ))}
    </div>
    
    <!-- Trust Badges -->
    <div class="flex items-center justify-center gap-8 mt-12 text-white/30">
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-medium">⚡ 100% Cloud</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-medium">🔒 HIPAA-ready</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-medium">🇻🇪 Hecho en Venezuela</span>
      </div>
    </div>
  </div>
</section>