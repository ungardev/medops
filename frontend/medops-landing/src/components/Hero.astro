---
const features = [
  { id: 'cie11', label: 'CIE-11 WHO', img: '/screenshots/cie11.svg' },
  { id: 'cirugia', label: 'Cirugía', img: '/screenshots/cirugia.svg' },
  { id: 'hospi', label: 'Hospitalización', img: '/screenshots/hospi.svg' },
  { id: 'sala', label: 'Sala Live', img: '/screenshots/sala.svg' },
  { id: 'pagos', label: 'Pagos P2C', img: '/screenshots/pagos.svg' },
  { id: 'sede', label: 'Multi-sede', img: '/screenshots/sede.svg' },
];
---

<section class="relative min-h-screen flex flex-col justify-start overflow-hidden pt-28">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] via-transparent to-transparent"></div>
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-emerald-500/5 rounded-full blur-[120px]"></div>
  
  <div class="relative z-10 max-w-[1000px] mx-auto px-6 text-center">
    <!-- MEDOPZ Logo - más grande -->
    <img src="/medopz_fuente_blanco.svg" alt="MEDOPZ" class="w-full max-w-[280px] mx-auto mb-4" />
    
    <!-- Subtitle -->
    <h1 class="text-base sm:text-lg font-medium text-white/80 tracking-wide mb-2">
      Gestión de salud elite para médicos especialistas, pacientes e instituciones de Venezuela
    </h1>
    
    <!-- Carousel Container -->
    <div class="relative mt-6 mb-4">
      <!-- Left Arrow -->
      <button id="prevBtn" class="absolute left-0 top-1/2 -translate-y-1/2 z-20 w-10 h-10 flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/20 rounded-full text-white transition-all">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      
      <!-- Screenshot Area -->
      <div id="screenshotArea" class="w-full aspect-video bg-black/40 border border-white/10 rounded-xl overflow-hidden">
        <div class="w-full h-full flex items-center justify-center text-white/30 text-sm">
          Screenshot: CIE-11 WHO
        </div>
      </div>
      
      <!-- Right Arrow -->
      <button id="nextBtn" class="absolute right-0 top-1/2 -translate-y-1/2 z-20 w-10 h-10 flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/20 rounded-full text-white transition-all">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
    
    <!-- Feature Pills - interactivos -->
    <div class="flex flex-wrap items-center justify-center gap-2">
      {features.map((feature, index) => (
        <button 
          data-index={index}
          class="feature-tab px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-[11px] font-medium text-white/60 whitespace-nowrap hover:bg-white/10 hover:text-white transition-all"
        >
          {feature.label}
        </button>
      ))}
    </div>
  </div>
</section>

<script>
  const features = [
    { id: 'cie11', label: 'CIE-11 WHO', img: '/screenshots/cie11.svg' },
    { id: 'cirugia', label: 'Cirugía', img: '/screenshots/cirugia.svg' },
    { id: 'hospi', label: 'Hospitalización', img: '/screenshots/hospi.svg' },
    { id: 'sala', label: 'Sala Live', img: '/screenshots/sala.svg' },
    { id: 'pagos', label: 'Pagos P2C', img: '/screenshots/pagos.svg' },
    { id: 'sede', label: 'Multi-sede', img: '/screenshots/sede.svg' },
  ];
  
  let currentIndex = 0;
  const screenshotArea = document.getElementById('screenshotArea');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const tabs = document.querySelectorAll('.feature-tab');
  
  function updateScreenshot(index) {
    currentIndex = index;
    screenshotArea.innerHTML = `<div class="w-full h-full flex items-center justify-center text-white/30 text-sm">Screenshot: ${features[index].label}</div>`;
    
    tabs.forEach((tab, i) => {
      if (i === index) {
        tab.classList.remove('bg-white/5', 'text-white/60');
        tab.classList.add('bg-emerald-500/20', 'border-emerald-500/30', 'text-emerald-400');
      } else {
        tab.classList.remove('bg-emerald-500/20', 'border-emerald-500/30', 'text-emerald-400');
        tab.classList.add('bg-white/5', 'text-white/60');
      }
    });
  }
  
  tabs.forEach((tab, index) => {
    tab.addEventListener('click', () => updateScreenshot(index));
  });
  
  prevBtn.addEventListener('click', () => {
    const newIndex = currentIndex === 0 ? features.length - 1 : currentIndex - 1;
    updateScreenshot(newIndex);
  });
  
  nextBtn.addEventListener('click', () => {
    const newIndex = currentIndex === features.length - 1 ? 0 : currentIndex + 1;
    updateScreenshot(newIndex);
  });
  
  updateScreenshot(0);
</script>