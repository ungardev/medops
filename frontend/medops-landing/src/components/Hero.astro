---
const features = [
  { label: 'CIE-11 WHO' },
  { label: 'SNOMED CT' },
  { label: 'Cirugía' },
  { label: 'Hospitalización' },
  { label: 'Pagos P2C' },
  { label: 'Multi-sede' },
];
---

<section class="relative min-h-screen bg-[#050608] flex flex-col items-center justify-center overflow-hidden pt-36 pb-24 px-6">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1a1e23_1px,transparent_1px),linear-gradient(to_bottom,#1a1e23_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-[0.08]"></div>

  <div class="relative z-10 max-w-[1100px] mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#1a1e23] bg-[#0c0e12] mb-8 animate-fade-in">
      <span class="flex h-2 w-2 relative">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#10b981] opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-[#10b981]"></span>
      </span>
      <span class="text-xs font-semibold tracking-wider text-slate-200 uppercase">Infraestructura Transaccional de Grado Bancario</span>
    </div>

    <h1 class="text-5xl md:text-7xl font-bold text-white tracking-tight leading-[1.05] max-w-[950px] mx-auto">
      El Command Center Clínico,<br />
      <span class="bg-gradient-to-r from-[#10b981] to-[#059669] bg-clip-text text-transparent">Diagnóstico y Transaccional Inteligente</span>
    </h1>
    
    <p class="mt-8 text-lg md:text-xl text-slate-200 max-w-[750px] mx-auto font-normal leading-relaxed">
      Workstation de nivel corporativo para médicos especialistas e instituciones en Venezuela. 
      Liquidación automatizada, control normativo MPPS y motores de búsqueda clínica indexada.
    </p>
    
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-5">
      <a href="https://app.medopz.com/" target="_blank" class="w-full sm:w-auto px-8 py-4 bg-[#10b981] text-black font-bold rounded-xl hover:bg-[#0d9488] transition-all duration-300 shadow-[0_0_30px_rgba(16,185,129,0.2)] text-center text-base">
        Portal Doctor →
      </a>
      <a href="https://patient.medopz.com/" target="_blank" class="w-full sm:w-auto px-8 py-4 border border-[#1a1e23] bg-[#0c0e12] text-white font-semibold rounded-xl hover:bg-[#1a1e23] hover:border-[#10b981]/50 transition-all duration-300 text-center text-base">
        Portal Paciente
      </a>
    </div>
  </div>

  <!-- Telemetry Dashboard -->
  <div class="relative mt-20 w-full max-w-[1000px] mx-auto bg-[#0c0e12] border border-[#1a1e23] rounded-2xl shadow-[0_0_50px_rgba(0,0,0,0.9)] overflow-hidden group hover:border-[#10b981]/30 transition-all duration-500">
    <div class="flex items-center justify-between px-5 py-3 border-b border-[#1a1e23] bg-[#07080a]">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-[#1a1e23]"></div>
        <div class="w-3 h-3 rounded-full bg-[#1a1e23]"></div>
        <div class="w-3 h-3 rounded-full bg-[#1a1e23]"></div>
      </div>
      <div class="text-xs text-slate-500 font-mono tracking-widest">MEDOPZ_CORE_TELEMETRY // LIVE</div>
      <div class="w-12"></div>
    </div>
    
    <div class="p-6 md:p-8 grid grid-cols-1 md:grid-cols-3 gap-6 bg-[#050608]/50">
      <div class="bg-[#0c0e12] border border-[#1a1e23] rounded-xl p-5 font-mono">
        <div class="flex justify-between text-xs text-slate-400">
          <span>MONITOR_LIQUIDACIÓN</span>
          <span class="text-[#10b981] font-bold">Bs. / $</span>
        </div>
        <div class="text-2xl font-bold text-white mt-3 font-sans">99.8%</div>
        <p class="text-[11px] text-slate-400 mt-1">Conciliación automatizada BCV Rate</p>
        <div class="mt-4 h-16 w-full flex items-end">
          <svg class="w-full h-full stroke-[#10b981] stroke-2 fill-none" viewBox="0 0 100 20">
            <path d="M0,18 Q15,5 30,12 T60,3 T90,15 L100,2" stroke-linecap="round"></path>
          </svg>
        </div>
      </div>

      <div class="bg-[#0c0e12] border border-[#1a1e23] rounded-xl p-5 font-mono">
        <div class="flex justify-between text-xs text-slate-400">
          <span>CORE_INDEX_ENGINE</span>
          <span class="text-[#06b6d4]">ACTIVE</span>
        </div>
        <div class="text-2xl font-bold text-white mt-3 font-sans">+140K</div>
        <p class="text-[11px] text-slate-400 mt-1">Registros CIE-11 & SNOMED CT</p>
        <div class="mt-4 space-y-1.5 text-[10px]">
          <div class="flex justify-between text-slate-400 bg-[#050608] px-2 py-1 border border-[#1a1e23] rounded">
            <span>> Query: "Infección Resp"</span>
            <span class="text-slate-500">0.4ms</span>
          </div>
          <div class="flex justify-between text-[#10b981] bg-[#10b981]/5 px-2 py-1 border border-[#10b981]/20 rounded">
            <span>✓ Match: J06.9 (CIE-11)</span>
            <span>99% Acc</span>
          </div>
        </div>
      </div>

      <div class="bg-[#0c0e12] border border-[#1a1e23] rounded-xl p-5 font-mono">
        <div class="flex justify-between text-xs text-slate-400">
          <span>COMPLIANCE_GATE</span>
          <span class="text-[#10b981]">SECURE</span>
        </div>
        <div class="text-2xl font-bold text-white mt-3 font-sans">MPPS</div>
        <p class="text-[11px] text-slate-400 mt-1">Validación de Sellado Criptográfico</p>
        <div class="mt-5 flex items-center gap-3 bg-[#050608] p-2 border border-[#1a1e23] rounded">
          <div class="h-2 w-2 rounded-full bg-[#10b981] animate-pulse"></div>
          <span class="text-[10px] text-slate-300">Firma Digital Verificada ID: 2026-X9</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    0% { opacity: 0; transform: translateY(10px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }
  
  @keyframes ping {
    75%, 100% {
      transform: scale(2);
      opacity: 0;
    }
  }
  
  .animate-ping {
    animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
</style>