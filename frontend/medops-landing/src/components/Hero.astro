---
const features = [
  'CIE-11 WHO',
  'Cirugía',
  'Hospitalización',
  'Sala Live',
  'Pagos P2C',
  'Multi-sede',
];
---
<section class="relative min-h-screen flex flex-col justify-start overflow-hidden pt-28">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] via-transparent to-transparent"></div>
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-emerald-500/5 rounded-full blur-[120px]"></div>
  
  <div class="relative z-10 max-w-[900px] mx-auto px-6 text-center">
    <!-- MEDOPZ Logo - centrado -->
    <img src="/medopz_fuente_blanco.svg" alt="MEDOPZ" class="w-full max-w-[200px] mx-auto mb-4" />
    
    <!-- Subtitle -->
    <h1 class="text-base sm:text-lg font-medium text-white/70 tracking-wide mb-4">
      Workstation de salud elite de Venezuela
    </h1>
    
    <!-- Description -->
    <p class="text-sm text-white/50 max-w-lg mx-auto mb-6 leading-relaxed">
      Consulta, cirugía, hospitalización, pagos y más.
    </p>
    
    <!-- CTA Buttons -->
    <div class="flex flex-wrap items-center justify-center gap-3 mb-6">
      <a 
        href="#contact"
        class="inline-flex items-center justify-center gap-2 px-6 py-2 bg-emerald-500/15 hover:bg-emerald-500/25 border border-emerald-500/25 text-emerald-400 text-[11px] font-medium rounded-lg transition-all"
      >
        Solicitar Demo
      </a>
      <a 
        href="http://localhost:8080/login"
        class="inline-flex items-center justify-center gap-2 px-6 py-2 bg-white/5 hover:bg-white/10 border border-white/15 text-white/70 text-[11px] font-medium rounded-lg transition-all"
      >
        Acceder Doctor
      </a>
    </div>
    
    <!-- Feature Pills -->
    <div class="flex flex-wrap items-center justify-center gap-2">
      {features.map((feature) => (
        <span class="px-2 py-0.5 bg-white/5 border border-white/10 rounded text-[9px] font-medium text-white/50 whitespace-nowrap">
          {feature}
        </span>
      ))}
    </div>
  </div>
</section>