---
const features = [
  { label: 'CIE-11 WHO' },
  { label: 'SNOMED CT' },
  { label: 'Cirugía' },
  { label: 'Hospitalización' },
  { label: 'Pagos P2C' },
  { label: 'Multi-sede' },
];
---

<section class="relative min-h-screen bg-[#050608] flex flex-col items-center justify-center overflow-hidden pt-32 pb-20 px-6">
  <!-- Data Grid Engineering Background -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1a1e23_1px,transparent_1px),linear-gradient(to_bottom,#1a1e23_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-[0.04]"></div>

  <div class="relative z-10 max-w-[1100px] mx-auto text-center">
    <!-- Logo Brand -->
    <div class="mb-12">
      <img src="/medopz_fuente_blanco.svg" alt="MEDOPZ" class="w-full max-w-[260px] mx-auto" />
    </div>

    <!-- H1 - Volumetric Text Gradient (Linear / Palantir) -->
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-transparent bg-clip-text bg-gradient-to-b from-[#FFFFFF] via-[#F1F5F9] to-[#94A3B8] max-w-[900px] mx-auto leading-[1.15]">
      Workstation elite para médicos especialistas, pacientes e instituciones en Venezuela.
    </h1>
    
    <!-- Feature Pills -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      {features.map((feature) => (
        <span class="px-4 py-2 bg-[#0c0e12]/50 border border-slate-800/60 rounded-lg text-[12px] font-medium text-slate-400">
          {feature.label}
        </span>
      ))}
    </div>
    
    <!-- CTA Buttons - Apple Health Style -->
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-5">
      <!-- Portal Doctor - Gradient Green Clinical -->
      <a 
        href="https://app.medopz.com/" 
        target="_blank"
        class="group w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 bg-gradient-to-r from-[#064e3b] to-[#047857] text-white font-semibold rounded-xl border border-[#10b981]/30 hover:border-[#10b981]/60 hover:shadow-[0_0_25px_rgba(16,185,129,0.25)] transition-all duration-300 text-[15px]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/>
          <path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/>
          <circle cx="20" cy="10" r="2"/>
        </svg>
        Portal Doctor
        <span class="ml-1 opacity-70 group-hover:opacity-100">→</span>
      </a>
      
      <!-- Portal Paciente - Dark Glass Reflective -->
      <a 
        href="https://patient.medopz.com/" 
        target="_blank"
        class="group w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#0c0e12]/60 border border-slate-800 text-slate-200 font-medium rounded-xl hover:text-white hover:border-slate-700 hover:bg-[#111318]/80 transition-all duration-300 text-[15px]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
        </svg>
        Portal Paciente
        <span class="ml-1 opacity-40 group-hover:opacity-70">→</span>
      </a>
    </div>
    
    <!-- Production Interface Frame - Apple Style Hardware -->
    <div class="relative mt-20 w-full max-w-[1000px] mx-auto bg-[#0a0b0d]/50 backdrop-blur-xl border border-slate-800/60 rounded-2xl h-[500px] flex items-center justify-center shadow-[0_0_50px_rgba(0,0,0,0.8)]">
      <span class="text-slate-600 text-sm font-mono tracking-wide">[ Interfaz de Producción MEDOPZ ]</span>
    </div>
  </div>
</section>

<style>
  @keyframes ping {
    75%, 100% {
      transform: scale(2);
      opacity: 0;
    }
  }
  
  .animate-ping {
    animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
</style>