---
const features = [
  'CIE-11 WHO',
  'Cirugía',
  'Hospitalización',
  'Sala Live',
  'Pagos P2C',
  'Multi-sede',
];
---
<section class="relative min-h-screen flex flex-col justify-start overflow-hidden pt-28">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] via-transparent to-transparent"></div>
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-emerald-500/5 rounded-full blur-[120px]"></div>
  
  <div class="relative z-10 max-w-[900px] mx-auto px-6 text-center">
    <!-- MEDOPZ Logo - más grande -->
    <img src="/medopz_fuente_blanco.svg" alt="MEDOPZ" class="w-full max-w-[280px] mx-auto mb-6" />
    
    <!-- Subtitle - blanco puro -->
    <h1 class="text-lg sm:text-xl font-medium text-white tracking-wide">
      Workstation de salud elite de Venezuela
    </h1>
    
    <!-- Feature Pills - más grandes como tabs para screenshots -->
    <div class="flex flex-wrap items-center justify-center gap-3 mt-8">
      {features.map((feature) => (
        <span class="px-4 py-2 bg-white/10 border border-white/20 rounded-lg text-[12px] font-medium text-white whitespace-nowrap hover:bg-white/20 cursor-pointer transition-all">
          {feature}
        </span>
      ))}
    </div>
  </div>
</section>