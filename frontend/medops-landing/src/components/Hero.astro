---

<section class="relative min-h-screen bg-[#050608] flex flex-col items-center justify-center overflow-hidden pt-32 pb-20 px-6">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1a1e23_1px,transparent_1px),linear-gradient(to_bottom,#1a1e23_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-[0.04]"></div>

  <div class="relative z-10 max-w-[1100px] mx-auto text-center">
    <div class="mb-12">
      <img src="/medopz_fuente_blanco.svg" alt="MEDOPZ" width="668" height="78" class="w-full max-w-[500px] mx-auto" />
    </div>

    <h1 class="text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white mx-auto leading-[1]">
      Plataforma Healthtech Elite
    </h1>

    <p class="text-xl md:text-2xl text-slate-300 mt-8 max-w-[600px] mx-auto leading-relaxed">
      Web App de Salud disponible en todos los dispositivos desktop, mobile y tablet
    </p>

    <div class="mt-16 flex flex-col sm:flex-row items-center justify-center gap-6">
      <a
        href="https://app.medopz.com/"
        target="_blank"
        class="group w-full sm:w-auto inline-flex items-center justify-center gap-3 px-10 py-5 bg-emerald-500/15 hover:bg-emerald-500/25 border border-emerald-500/25 text-emerald-400 font-semibold rounded-xl transition-all duration-300 text-lg"
      >
        Portal Doctor
        <span class="ml-1">→</span>
      </a>

      <a
        href="https://patient.medopz.com/"
        target="_blank"
        class="group w-full sm:w-auto inline-flex items-center justify-center gap-3 px-10 py-5 bg-white/5 hover:bg-white/10 border border-white/15 text-white font-semibold rounded-xl transition-all duration-300 text-lg"
      >
        Portal Paciente
        <span class="ml-1">→</span>
      </a>
    </div>
  </div>
</section>