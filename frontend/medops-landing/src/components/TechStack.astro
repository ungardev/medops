---
const techStack = [
  {
    category: 'FRONTEND',
    items: ['React 18', 'Vite', 'TypeScript', 'TailwindCSS'],
  },
  {
    category: 'BACKEND',
    items: ['Django 5', 'Django REST Framework', 'SimpleJWT'],
  },
  {
    category: 'DATABASE',
    items: ['NeonDB', 'PostgreSQL'],
  },
  {
    category: 'CLINICAL STANDARDS',
    items: ['ICD-11 WHO', 'SNOMED CT'],
  },
];
---

<section id="techstack" class="py-24 lg:py-32 px-6 bg-[#050608] relative border-t border-[#1a1e23]">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1a1e23_1px,transparent_1px),linear-gradient(to_bottom,#1a1e23_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-[0.04]"></div>

  <div class="max-w-[1200px] mx-auto relative">
    <div class="text-center mb-16">
      <span class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em]">Stack Tecnológico</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-4 tracking-tight">
        Infraestructura de Producción
      </h2>
      <p class="text-lg text-slate-300 mt-4 max-w-[700px] mx-auto leading-relaxed">
        Arquitectura moderna para operaciones médicas de nivel corporativo
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {techStack.map((stack) => (
        <div class="p-6 bg-[#0c0e12] border border-[#1a1e23] rounded-2xl">
          <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-wider mb-4 block">{stack.category}</span>
          <div class="space-y-3">
            {stack.items.map((item) => (
              <div class="flex items-center gap-3">
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-500/70 shrink-0"></div>
                <span class="text-sm text-white font-medium">{item}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>