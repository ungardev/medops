---
const integrations = [
  {
    icon: 'bcv',
    label: 'BCV',
    title: 'Tasa del Dólar',
    description: 'La tasa oficial en tiempo real',
    value: 'Siempre actualizada',
    subvalue: 'Sin recargos',
    badges: ['Actualización automática'],
  },
  {
    icon: 'bancaribe',
    label: 'BANCARIBE',
    title: 'Pagos con Tarjeta',
    description: 'Tus pacientes pagan con tarjeta o transferencia',
    value: 'Recibe en tu cuenta',
    subvalue: 'Sin complicaciones',
    badges: ['Pagos seguros'],
  },
  {
    icon: 'wallet',
    label: 'WALLET',
    title: 'Tus Ganancias',
    description: 'Acumula y retira cuando quieras',
    value: 'Desde $20 USD',
    subvalue: 'En 24 horas',
    badges: ['3% por transacción'],
  },
];
---

<section id="integrations" class="py-24 lg:py-32 px-6 bg-transparent relative border-t border-[#1a1e23]">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1a1e23_1px,transparent_1px),linear-gradient(to_bottom,#1a1e23_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-[0.04]"></div>

  <div class="max-w-[1200px] mx-auto relative">
    <div class="text-center mb-16">
      <span class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em]">Finanzas</span>
      <h2 class="text-5xl md:text-6xl font-bold text-white mt-4 tracking-tight">
        Infraestructura Financiera
      </h2>
      <p class="text-xl text-slate-300 mt-4 max-w-[500px] mx-auto">
        Pagos en alianza con Bancaribe
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {integrations.map((integration) => (
        <div class="group relative p-8 bg-[#0c0e12] border border-[#1a1e23] rounded-2xl transition-all duration-500 hover:border-emerald-500/30 text-center">
          <div class="absolute top-0 left-8 right-8 h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="w-16 h-16 rounded-2xl bg-[#0a0a0b] border border-[#1a1e23] flex items-center justify-center mx-auto mb-6 transition-all duration-300 group-hover:border-emerald-500/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" class="text-slate-200 group-hover:text-emerald-400 transition-colors" aria-hidden="true" role="img">
              <use href={`/icons.svg#icon-${integration.icon}`} />
            </svg>
          </div>

          <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest mb-2 block">{integration.label}</span>
          <h3 class="text-2xl font-bold text-white mb-2">{integration.title}</h3>
          <p class="text-sm text-slate-400 mb-6">{integration.description}</p>

          <div class="text-3xl font-bold text-white mb-3">{integration.value}</div>
          <div class="text-xs text-slate-500 mb-4">{integration.subvalue}</div>

          <div class="flex flex-wrap justify-center gap-2">
            {integration.badges.map((badge) => (
              <span class="text-xs font-medium text-emerald-400 bg-emerald-500/10 px-3 py-1.5 rounded-full border border-emerald-500/20">{badge}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>