---
const integrations = [
  {
    icon: 'bcv',
    label: 'BCV',
    title: 'Tasa Oficial',
    description: 'Tasa del BCV en tiempo real',
    value: 'Milisegundos',
    subvalue: 'Protección patrimonial',
    badges: ['Milisegundos', 'Mitigación de riesgo'],
  },
  {
    icon: 'bancaribe',
    label: 'BANCARIBE',
    title: 'Pagos Instantáneos',
    description: 'Cobros y transferencias automáticas',
    value: 'C2P / P2P',
    subvalue: 'Webhooks de conciliación',
    badges: ['Dispersión automática', 'Conciliación real'],
  },
  {
    icon: 'wallet',
    label: 'WALLET',
    title: 'Wallet Doctor',
    description: 'Acumulación y retiros instantáneos',
    value: 'Instant / Batch',
    subvalue: 'Mínimo $20 USD',
    badges: ['3% comisión', 'Auto-retiro'],
  },
];
---

<section id="integrations" class="py-24 lg:py-32 px-6 bg-[#050608] relative border-t border-[#1a1e23]">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1a1e23_1px,transparent_1px),linear-gradient(to_bottom,#1a1e23_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-[0.04]"></div>

  <div class="max-w-[1200px] mx-auto relative">
    <div class="text-center mb-16">
      <span class="text-xs font-bold text-emerald-400 uppercase tracking-[0.2em]">Financiero</span>
      <h2 class="text-5xl md:text-6xl font-bold text-white mt-4 tracking-tight">
        Pagos con Bancaribe
      </h2>
      <p class="text-xl text-slate-300 mt-4 max-w-[500px] mx-auto">
        Infraestructura financiera integrada
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {integrations.map((integration) => (
        <div class="group relative p-8 bg-[#0c0e12] border border-[#1a1e23] rounded-2xl transition-all duration-500 hover:border-emerald-500/30">
          <div class="absolute top-0 left-8 right-8 h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="w-14 h-14 rounded-xl bg-[#0a0a0b] border border-[#1a1e23] flex items-center justify-center mb-6 transition-all duration-300 group-hover:border-emerald-500/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" class="text-slate-200 group-hover:text-emerald-400 transition-colors">
              <use href={`/icons.svg#icon-${integration.icon}`} />
            </svg>
          </div>

          <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-wider mb-2 block">{integration.label}</span>
          <h3 class="text-2xl font-semibold text-white mb-3">{integration.title}</h3>
          <p class="text-sm text-slate-400 mb-6">{integration.description}</p>

          <div class="p-4 bg-[#050608] border border-[#1a1e23] rounded-xl">
            <div class="text-2xl font-bold text-white mb-1">{integration.value}</div>
            <div class="text-xs text-slate-400">{integration.subvalue}</div>
            {integration.badges && (
              <div class="flex flex-wrap gap-2 mt-3">
                {integration.badges.map((badge) => (
                  <span class="text-[10px] font-medium text-emerald-400/80 bg-emerald-500/10 px-2 py-1 rounded-full border border-emerald-500/20">{badge}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>