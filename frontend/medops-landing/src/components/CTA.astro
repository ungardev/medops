---

<section id="contact" class="py-24 lg:py-32 px-6 bg-transparent relative overflow-hidden">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1a1e23_1px,transparent_1px),linear-gradient(to_bottom,#1a1e23_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-[0.04]"></div>
  
  <div class="max-w-[900px] mx-auto relative">
    <div class="relative p-10 lg:p-14 bg-[#0c0e12]/80 backdrop-blur-xl border border-[#1a1e23] rounded-2xl">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent"></div>
      
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-3xl pointer-events-none"></div>
      
      <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <span class="text-base font-bold text-emerald-400 uppercase tracking-[0.3em] mb-4 block">Despliegue Industrial</span>
          
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white tracking-tight leading-tight mb-6">
            ¿Listo para conocer MEDOPZ?
          </h2>
          
          <p class="text-base text-slate-300 leading-relaxed">
            Agenda una demo y conoce la plataforma en acción. Sin compromiso.
          </p>
        </div>
        
        <div class="flex flex-col gap-4">
          <a 
            href="mailto:info@medopz.com?subject=Solicitud de Demo MEDOPZ&body=Hola equipo MEDOPZ,%0A%0ASolicito una demo de la plataforma.%0A%0AInstitución:%0ARol:%0ANúmero de médicos:%0ACiudad:%0A%0AGracias."
            class="group relative flex items-center justify-center gap-3 px-8 py-5 bg-gradient-to-r from-emerald-500/20 to-emerald-600/10 hover:from-emerald-500/30 hover:to-emerald-600/20 border-2 border-emerald-500/30 hover:border-emerald-500/50 rounded-xl transition-all duration-300"
          >
            <span class="absolute inset-0 rounded-xl bg-gradient-to-r from-emerald-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
            <span class="relative text-lg font-semibold text-white">Agendar Demo</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="relative text-emerald-400"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          
          <a 
            href="mailto:info@medopz.com?subject=Consulta sobre Licenciamiento"
            class="flex items-center justify-center gap-3 px-8 py-5 bg-[#0a0a0b] border border-[#1a1e23] hover:border-[#2a2e33] text-white/90 hover:text-white rounded-xl transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span class="text-base font-medium">Hablar con un Asesor</span>
          </a>
          
          <div class="flex flex-wrap items-center justify-center gap-4 pt-4">
            <span class="text-[10px] text-slate-400 uppercase tracking-wider">Canal Cifrado</span>
            <span class="w-1 h-1 rounded-full bg-[#1a1e23]"></span>
            <span class="text-[10px] text-slate-400 uppercase tracking-wider">Respuesta &lt; 2 Horas</span>
            <span class="w-1 h-1 rounded-full bg-[#1a1e23]"></span>
            <span class="text-[10px] text-slate-400 uppercase tracking-wider">Despliegue Inmediato</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>