---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: 'http://localhost:8080/login', label: 'Doctor' },
  { href: 'http://localhost:8080/patient/login', label: 'Paciente' },
  { href: '#pricing', label: 'Precios' },
];
---

<nav id="navbar" class="fixed top-2 left-1/2 -translate-x-1/2 z-50 bg-white/5 backdrop-blur-xl saturate-180 border border-white/10 rounded-full transition-all duration-300 overflow-hidden" style="width: auto; min-width: 260px; max-width: 95vw;">
  <div class="flex items-center justify-center gap-1 sm:gap-1 px-2 sm:px-2 py-2 sm:py-1">
    <a href="/" class="text-[12px] sm:text-[13px] font-semibold text-white hover:text-emerald-400 px-2 sm:px-2.5 py-1 rounded-lg hover:bg-white/5 transition-all">Home</a>
    <a href="http://localhost:8080/login" class="text-[12px] sm:text-[13px] font-semibold text-white hover:text-emerald-400 px-2 sm:px-2.5 py-1 rounded-lg hover:bg-white/5 transition-all">Doctor</a>
    
    <a href="/" class="flex items-center mx-1 sm:mx-1">
      <img src="/medopz_logo_blanco_solo.svg" alt="MEDOPZ" class="h-12 w-12 sm:h-10 sm:w-10 object-contain" />
    </a>
    
    <a href="http://localhost:8080/patient/login" class="text-[12px] sm:text-[13px] font-semibold text-white hover:text-emerald-400 px-2 sm:px-2.5 py-1 rounded-lg hover:bg-white/5 transition-all">Paciente</a>
    <a href="#pricing" class="text-[12px] sm:text-[13px] font-semibold text-white hover:text-emerald-400 px-2 sm:px-2.5 py-1 rounded-lg hover:bg-white/5 transition-all">Planes</a>
  </div>
</nav>

<script>
  const nav = document.getElementById('navbar');
  let lastScroll = 0;
  
  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    
    if (currentScroll > lastScroll && currentScroll > 100) {
      nav.style.transform = 'translate(-50%, -200%)';
    } else {
      nav.style.transform = 'translate(-50%, 0)';
    }
    
    lastScroll = currentScroll;
  });
</script>