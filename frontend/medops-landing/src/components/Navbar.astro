---
const navLinks = [
  { href: 'https://app.medopz.com/', label: 'Doctor' },
  { href: 'https://patient.medopz.com/', label: 'Paciente' },
  { href: '#pricing', label: 'Precios' },
];
---

<nav id="navbar" class="fixed top-3 left-1/2 -translate-x-1/2 z-50 bg-black-surface/80 backdrop-blur-xl border border-black-border rounded-full transition-all duration-300" style="width: auto; min-width: 260px; max-width: 95vw;">
  <div class="flex items-center justify-center gap-1 px-3 py-2">
    <a href="/" class="text-[12px] font-semibold text-text-secondary hover:text-white px-3 py-1.5 rounded-lg hover:bg-white/5 transition-all">Home</a>
    
    <div class="w-px h-5 bg-black-border mx-1"></div>
    
    <a href="https://app.medopz.com/" target="_blank" class="text-[12px] font-semibold text-text-secondary hover:text-accent-blue px-3 py-1.5 rounded-lg hover:bg-accent-blue/5 transition-all">Doctor</a>
    
    <a href="/" class="flex items-center mx-1">
      <img src="/medopz_logo_blanco_solo.svg" alt="MEDOPZ" class="h-8 w-8" />
    </a>
    
    <a href="https://patient.medopz.com/" target="_blank" class="text-[12px] font-semibold text-text-secondary hover:text-accent-blue px-3 py-1.5 rounded-lg hover:bg-accent-blue/5 transition-all">Paciente</a>
    
    <div class="w-px h-5 bg-black-border mx-1"></div>
    
    <a href="#pricing" class="text-[12px] font-semibold text-text-secondary hover:text-white px-3 py-1.5 rounded-lg hover:bg-white/5 transition-all">Precios</a>
  </div>
</nav>

<script>
  const nav = document.getElementById('navbar');
  let lastScroll = 0;
  
  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    
    if (currentScroll > lastScroll && currentScroll > 100) {
      nav.style.transform = 'translate(-50%, -200%)';
    } else {
      nav.style.transform = 'translate(-50%, 0)';
    }
    
    lastScroll = currentScroll;
  });
</script>