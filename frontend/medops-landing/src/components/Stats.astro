---
const stats = [
  { value: '10K+', label: 'Pacientes Registrados' },
  { value: '50+', label: 'Médicos Activos' },
  { value: '99.9%', label: 'Uptime Garantizado' },
  { value: '<2s', label: 'Respuesta Promedio' },
];
---
<section class="py-16 px-6 border-y border-white/5">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-bold text-white tracking-tighter mb-1">{stat.value}</div>
          <div class="text-[10px] font-medium text-white/30 uppercase tracking-wider">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>