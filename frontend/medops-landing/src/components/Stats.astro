---
const stats = [
  { value: '+140K', label: 'Códigos Médicos Indexados' },
  { value: 'ICD-11', label: 'Estándar WHO Official' },
  { value: 'Bs. / $', label: 'Liquidación Directa' },
  { value: '<100ms', label: 'Tiempo de Respuesta' },
];
---

<section class="py-12 lg:py-16 border-y border-[#1a1e23] bg-transparent">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {stats.map((stat) => (
        <div class="group relative p-6 bg-[#0c0e12] border border-[#1a1e23] rounded-xl transition-all duration-300 hover:border-emerald-500/20">
          <!-- Value -->
          <div class="text-3xl lg:text-4xl font-bold text-white tracking-tight mb-2">{stat.value}</div>
          
          <!-- Label -->
          <div class="text-sm text-slate-400 font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>