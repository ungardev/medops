---
const stats = [
  { value: 'ICD-11', label: 'Estándar WHO', icon: 'globe' },
  { value: '500+', label: 'Capacidad médicos', icon: 'users' },
  { value: '99.9%', label: 'Uptime SLA', icon: 'activity' },
  { value: '<100ms', label: 'Tiempo de respuesta', icon: 'zap' },
];
---

<section class="py-10 sm:py-16 px-4 sm:px-6 border-y border-white/10 overflow-hidden">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-2 sm:gap-4">
      {stats.map((stat, index) => (
        <div 
          class="group relative overflow-hidden rounded-lg p-6 lg:p-8 transition-all duration-300 hover:border-white/20"
        >
          <!-- Glassmorphism Background -->
          <div class="absolute inset-0 bg-gradient-to-b from-white/[0.08] to-white/[0.02] backdrop-blur-xl rounded-lg border border-white/[0.08] transition-all duration-300 group-hover:border-white/[0.15] group-hover:from-white/[0.12]"></div>
          
          <!-- Glow Effect -->
          <div class="absolute inset-0 rounded-lg opacity-0 transition-all duration-500 group-hover:opacity-100" style="background: radial-gradient(circle at 50% 0%, rgba(16, 185, 129, 0.15) 0%, transparent 60%);"></div>
          
          <!-- Content -->
          <div class="relative z-10">
            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl bg-white/[0.05] border border-white/10 flex items-center justify-center mb-4 transition-all duration-300 group-hover:bg-white/[0.1] group-hover:border-emerald-500/30 group-hover:shadow-[0_0_20px_rgba(16,185,129,0.2)]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/60 group-hover:text-emerald-400 transition-all duration-300 group-hover:drop-shadow-[0_0_8px_rgba(16,185,129,0.5)]">
                {stat.icon === 'globe' && <><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></>}
                {stat.icon === 'users' && <><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
                {stat.icon === 'activity' && <><path d="M22 12h-4l-3 9-5-13-3 9H2"/></>}
                {stat.icon === 'zap' && <><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></>}
              </svg>
            </div>
            
            <!-- Value -->
            <div class="text-3xl lg:text-4xl font-bold text-white tracking-tight mb-1">{stat.value}</div>
            
            <!-- Label -->
            <div class="text-[11px] font-medium text-white/50 uppercase tracking-wider">{stat.label}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>