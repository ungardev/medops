---
const geoStats = [
  { value: '23', label: 'Estados' },
  { value: '335', label: 'Municipios' },
  { value: '1.100+', label: 'Parroquias' },
  { value: '100%', label: 'Cobertura' },
];
---

<section class="py-12 lg:py-16 border-y border-[#1a1e23] bg-transparent">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center mb-10">
      <span class="text-base font-bold text-emerald-400 uppercase tracking-[0.2em]">Geografía</span>
      <h3 class="text-3xl md:text-4xl font-bold text-white mt-2">Cobertura Nacional Venezuela</h3>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {geoStats.map((stat) => (
        <div class="group relative p-6 bg-[#0c0e12] border border-[#1a1e23] rounded-xl transition-all duration-300 hover:border-emerald-500/20">
          <div class="text-3xl lg:text-4xl font-bold text-white tracking-tight mb-2">{stat.value}</div>
          <div class="text-base text-slate-400 font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>