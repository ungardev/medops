---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Plataforma Healthtech Elite de Venezuela. Web App de Salud para doctores y pacientes." } = Astro.props;
---
<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050608" />
    
    <title>{title} | MEDOPZ</title>
    
    <link rel="icon" type="image/svg+xml" href="/medopz_logo_blanco_solo.svg" />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://medopz.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:site_name" content="MEDOPZ" />
    <meta property="og:locale" content="es_VE" />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@medopz" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.png" />
    

    
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://medopz.com/#organization",
          "name": "MEDOPZ",
          "url": "https://medopz.com",
          "logo": "https://medopz.com/medopz_logo_blanco_solo.svg",
          "description": "Plataforma Healthtech Elite de Venezuela. Web App de Salud para doctores y pacientes.",
          "address": {
            "@type": "PostalAddress",
            "addressCountry": "VE"
          },
          "sameAs": [
            "https://twitter.com/medopz"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "https://medopz.com/#website",
          "url": "https://medopz.com",
          "name": "MEDOPZ",
          "publisher": { "@id": "https://medopz.com/#organization" },
          "description": "Plataforma Healthtech Elite de Venezuela. Web App de Salud para doctores y pacientes.",
          "inLanguage": "es-VE"
        },
        {
          "@type": "MedicalBusiness",
          "@id": "https://medopz.com/#medicalbusiness",
          "name": "MEDOPZ",
          "description": "Plataforma de gestión médica para consultorios, clínicas y hospitales",
          "url": "https://medopz.com",
          "publisher": { "@id": "https://medopz.com/#organization" },
          "medicalSpecialty": "GeneralMedicine",
          "address": {
            "@type": "PostalAddress",
            "addressCountry": "VE"
          }
        }
      ]
    }
    </script>
    
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      html, body {
        overflow-x: hidden;
        max-width: 100vw;
      }
      
      html {
        scroll-behavior: auto;
      }
      
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        background-color: #050608;
        background-image: linear-gradient(rgba(26, 30, 35, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(26, 30, 35, 0.04) 1px, transparent 1px);
        background-size: 4rem 4rem;
        color: #e1e8ed;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      
      ::-webkit-scrollbar {
        width: 6px;
      }
      
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      
      ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
      }
      
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
      }
      
      ::selection {
        background: rgba(56, 161, 255, 0.3);
        color: #ffffff;
      }
    </style>
  </head>
  <body>
    <div class="fixed bottom-0 left-0 w-[1200px] h-[1200px] bg-emerald-500/[0.15] rounded-full blur-[40px] pointer-events-none -z-10"></div>
    <div class="fixed top-0 right-0 w-[1000px] h-[1000px] bg-emerald-500/[0.12] rounded-full blur-[35px] pointer-events-none -z-10"></div>
    <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1400px] h-[1400px] bg-emerald-500/[0.08] rounded-full blur-[50px] pointer-events-none -z-10"></div>
    <slot />
  </body>
</html>