---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Plataforma Healthtech Elite de Venezuela. Web App de Salud para doctores y pacientes." } = Astro.props;
---
<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050608" />
    
    <title>{title} | MEDOPZ</title>
    
    <link rel="icon" type="image/svg+xml" href="/medopz_logo_blanco_solo.svg" />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://medopz.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:site_name" content="MEDOPZ" />
    <meta property="og:locale" content="es_VE" />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@medopz" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.png" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Manrope:wght@200;300;400;500;600&display=swap&display=swap" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Manrope:wght@200;300;400;500;600&display=swap&display=swap" />
    </noscript>
    
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://medopz.com/#organization",
          "name": "MEDOPZ",
          "url": "https://medopz.com",
          "logo": "https://medopz.com/medopz_logo_blanco_solo.svg",
          "description": "Plataforma Healthtech Elite de Venezuela. Web App de Salud para doctores y pacientes.",
          "address": {
            "@type": "PostalAddress",
            "addressCountry": "VE"
          },
          "sameAs": [
            "https://twitter.com/medopz"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "https://medopz.com/#website",
          "url": "https://medopz.com",
          "name": "MEDOPZ",
          "publisher": { "@id": "https://medopz.com/#organization" },
          "description": "Plataforma Healthtech Elite de Venezuela. Web App de Salud para doctores y pacientes.",
          "inLanguage": "es-VE"
        },
        {
          "@type": "MedicalBusiness",
          "@id": "https://medopz.com/#medicalbusiness",
          "name": "MEDOPZ",
          "description": "Plataforma de gestión médica para consultorios, clínicas y hospitales",
          "url": "https://medopz.com",
          "publisher": { "@id": "https://medopz.com/#organization" },
          "medicalSpecialty": "GeneralMedicine",
          "address": {
            "@type": "PostalAddress",
            "addressCountry": "VE"
          }
        }
      ]
    }
    </script>
    
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      html, body {
        overflow-x: hidden;
        max-width: 100vw;
      }
      
      html {
        scroll-behavior: auto;
      }
      
      body {
        font-family: 'Inter', 'Manrope', ui-sans-serif, system-ui;
        background-color: #050608;
        color: #e1e8ed;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      
      ::-webkit-scrollbar {
        width: 6px;
      }
      
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      
      ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
      }
      
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
      }
      
      ::selection {
        background: rgba(56, 161, 255, 0.3);
        color: #ffffff;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>